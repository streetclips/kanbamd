lejandrocantero/kanbamd\",\n  \"version\": \"1.4.3\",\n  \"description\": \"Manage Kanban boards backed by Markdown files, frontmatter, and column folders.\",\n  \"type\": \"module\",\n  \"main\": \"./dist/index.js\",\n  \"types\": \"./dist/index.d.ts\",\n  \"exports\": {\n    \".\": {\n      \"types\": \"./dist/index.d.ts\",\n      \"import\": \"./dist/index.js\"\n    }\n  },\n  \"bin\": {\n    \"kanbamd\": \"./dist/cli.js\"\n  },\n  \"files\": [\n    \"dist\"\n  ],\n  \"scripts\": {\n    \"build\": \"tsc -p tsconfig.json\",\n    \"format\": \"biome format . --write\",\n    \"lint\": \"biome check .\",\n    \"lint:fix\": \"biome check . --write\",\n    \"release\": \"node scripts/release.mjs\",\n    \"test\": \"vitest run\",\n    \"typecheck\": \"tsc -p tsconfig.typecheck.json\"\n  },\n  \"keywords\": [\n    \"kanban\",\n    \"markdown\",\n    \"frontmatter\",\n    \"typescript\"\n  ],\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"@inquirer/prompts\": \"^7.10.1\",\n    \"chalk\": \"^5.6.2\",\n    \"commander\": \"^12.1.0\",\n    \"fuse.js\": \"^7.1.0\",\n    \"gray-matter\": \"^4.0.3\",\n    \"slugify\": \"^1.6.6\"\n  },\n  \"devDependencies\": {\n    \"@biomejs/biome\": \"^1.9.4\",\n    \"@types/node\": \"^20.12.12\",\n    \"typescript\": \"^5.4.5\",\n    \"vitest\": \"^1.6.0\"\n  },\n  \"engines\": {\n    \"node\": \">=20\"\n  }\n}\n","numLines":54,"startLine":1,"totalLines":54}}}
