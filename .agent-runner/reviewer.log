  }\n308\t\n309\t    throw new DuplicateCardError(`Could not generate a unique slug for title: ${title}`)\n310\t  }\n311\t\n312\t  private async normalizeColumnOrder(column: string): Promise<void> {\n313\t    await this.writeOrderedCards(column, await this.listColumnCards(column))\n314\t  }\n315\t\n316\t  private async writeOrderedCards(column: string, cards: Card<T>[]): Promise<void> {\n317\t    await Promise.all(\n318\t      cards.map((card, index) => {\n319\t        const frontmatter = {\n320\t          ...card.frontmatter,\n321\t          order: index + 1,\n322\t        }\n323\t        return this.storage.writeCard(\n324\t          this.columnPath(column),\n325\t          card.fileName,\n326\t          stringifyCard(frontmatter, card.body),\n327\t        )\n328\t      }),\n329\t    )\n330\t  }\n331\t\n332\t  private assertColumn(column: string): string {\n333\t    if (!this.columns.includes(column)) {\n334\t      throw new ColumnNotFoundError(`Column is not defined: ${column}`)\n335\t    }\n336\t    return column\n337\t  }\n338\t\n339\t  private columnPath(column: string): string {\n340\t    return this.root ? path.join(this.root, column) : column\n341\t  }\n342\t\n343\t  private assertInitialized(): void {\n344\t    if (!this.initialized) {\n345\t      throw new Error(\"Kanbamd must be initialized with init() before use.\")\n346\t    }\n347\t  }\n348\t\n349\t  private enqueueWrite<R>(operation: () => Promise<R>): Promise<R> {\n350\t    const queued = this.writeQueue.then(operation, operation)\n351\t    this.writeQueue = queued.then(\n352\t      () => undefined,\n353\t      () => undefined,\n354\t    )\n355\t    return queued\n356\t  }\n357\t}\n358\t"}]},"parent_tool_use_id":null,"session_id":"7e10c329-12dd-4922-8869-d58b7dccb0a3","uuid":"bfa6a712-81a2-4be4-b948-970dcf4f2f1f","timestamp":"2026-05-03T16:57:26.878Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/Kanbamd.ts","content":"import path from \"node:path\"\nimport Fuse from \"fuse.js\