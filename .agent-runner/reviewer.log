{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NvGHB2nvmqcvRcehqGDB6M","type":"tool_result","content":"1\timport path from \"node:path\"\n2\timport Fuse from \"fuse.js\"\n3\timport {\n4\t  CardNotFoundError,\n5\t  ColumnNotFoundError,\n6\t  DuplicateCardError,\n7\t  InvalidStorageConfigurationError,\n8\t} from \"./errors.js\"\n9\timport {\n10\t  createSlug,\n11\t  parseCardFrontmatter,\n12\t  stringifyCard,\n13\t  toFileName,\n14\t  toId,\n15\t  validateCardId,\n16\t  validateColumnName,\n17\t  validateExtraFrontmatter,\n18\t  validateTags,\n19\t  validateTitle,\n20\t} from \"./helpers.js\"\n21\timport { FilesystemStorage, MemoryStorage, type StorageAdapter } from \"./storage.js\"\n22\timport type {\n23\t  Card,\n24\t  CardFrontmatter,\n25\t  CardLocator,\n26\t  CreateCardInput,\n27\t  ExtraFrontmatter,\n28\t  KanbamdOptions,\n29\t  ListCardsOptions,\n30\t  SearchCardsOptions,\n31\t  UpdateCardInput,\n32\t} from \"./types.js\"\n33\t\n34\tconst defaultOrderStep = 1\n35\t\n36\texport class Kanbamd<T extends ExtraFrontmatter = ExtraFrontmatter> {\n37\t  private readonly root?: string\n38\t  private readonly columns: string[]\n39\t  private readonly createRoot: boolean\n40\t  private readonly createColumns: boolean\n41\t  private readonly storage: StorageAdapter\n42\t  private writeQueue = Promise.resolve()\n43\t  private initialized = false\n44\t\n45\t  constructor(options: KanbamdOptions) {\n46\t    const storageKind = options.storage ?? \"filesystem\"\n47\t    this.root = options.root\n48\t    this.columns = [...options.columns]\n49\t    this.createRoot = options.createRoot ?? false\n50\t    this.createColumns = options.createColumns ?? true\n51\t\n52\t    if (this.columns.length === 0) {\n53\t      throw new ColumnNotFoundError(\"At least one column must be defined.\")\n54\t    }\n55\t\n56\t    for (const column of this.columns) {\n57\t      validateColumnName(column)\n58\t    }\n59\t\n60\t    if (storageKind === \"filesystem\" && !this.root) {\n61\t      throw new InvalidStorageConfigurationError(\"Filesystem storage requires a root option.\")\n62\t    }\n63\t\n64\t    if (storageKind === \"memory\" && !this.root && options.createRoot) {\n65\t      throw new InvalidStorageConfigurationError(\n66\t        \"createRoot is only meaningful when a root is provided.\",\n67\t      )\n68\t    }\n69\t\n70\t    this.storage = storageKind === \"memory\" ? new MemoryStorage() : new FilesystemStorage()\n71\t  }\n72\t\n73\t  async init(): Promise<void> {\n74\t    await this.storage.init({\n75\t      root: this.root,\n76\t      columns: this.columns,\n77\t      createRoot: this.createRoot,\n78\t      createColumns: this.createColumns,\n79\t    })\n80\t    this.initialized = true\n81\t  }\n82\t\n83\t  async listColumns(): Promise<string[]> {\n84\t    this.assertInitialized()\n85\t    return [...this.columns]\n86\t  }\n87\t\n88\t  async listCards(options: ListCardsOptions = {}): Promise<Card<T>[]> {\n89\t    this.assertInitialized()\n90\t    const columns = options.column ? [this.assertColumn(options.column)] : this.columns\n91\t    const cards = await Promise.all(columns.map((column) => this.listColumnCards(column)))\n92\t    return cards\n93\t      .flat()\n94\t      .sort((a, b) => a.column.localeCompare(b.column) || a.frontmatter.order - b.frontmatter.order)\n95\t  }\n96\t\n97\t  async getCard(locator: CardLocator): Promise<Card<T>> {\n98\t    this.assertInitialized()\n99\t    const column = this.assertColumn(locator.column)\n100\t    validateCardId(locator.id)\n101\t    return this.readCard(column, toFileName(locator.id))\n102\t  }\n103\t\n104\t  async createCard(columnInput: string, input: CreateCardInput<T>): Promise<Card<T>> {\n105\t    this.assertInitialized()\n106\t    const column = this.assertColumn(columnInput)\n107\t    validateTitle(input.title)\n108\t    validateTags(input.tags ?? [])\n109\t    validateExtraFrontmatter(input.frontmatter)\n110\t\n111\t    return this.enqueueWrite(async () => {\n112\t      const existingCards = await this.listColumnCards(column)\n113\t      const id = this.nextAvailableId(input.title, existingCards)\n114\t      const fileName = toFileName(id)\n115\t      const frontmatter = {\n116\t        title: input.title,\n117\t        tags: input.tags ?? [],\n118\t        order: existingCards.length + defaultOrderStep,\n119\t        ...(input.frontmatter ?? {}),\n120\t      } as CardFrontmatter<T>\n121\t\n122\t      const stored = await this.storage.writeCard(\n123\t        this.columnPath(column),\n124\t        fileName,\n125\t        stringifyCard(frontmatter, input.body ?? \"\"),\n126\t      )\n127\t      return this.toCard(column, fileName, stored.content, stored.createdAt, stored.updatedAt)\n128\t    })\n129\t  }\n130\t\n131\t  async updateCard(locator: CardLocator, input: UpdateCardInput<T>): Promise<Card<T>> {\n132\t    this.assertInitialized()\n133\t    validateExtraFrontmatter(input.frontmatter)\n134\t    const column = this.assertColumn(locator.column)\n135\t    validateCardId(locator.id)\n136\t    if (input.title !== undefined) {\n137\t      validateTitle(input.title)\n138\t    }\n139\t    if (input.tags !== undefined) {\n140\t      validateTags(input.tags)\n141\t    }\n142\t    const fileName = toFileName(locator.id)\n143\t\n144\t    return this.enqueueWrite(async () => {\n145\t      const card = await this.readCard(column, fileName)\n146\t      const nextFrontmatter = {\n147\t        ...card.frontmatter,\n148\t        ...(input.frontmatter ?? {}),\n149\t        ...(input.title === undefined ? {} : { title: input.title }),\n150\t        ...(input.tags === undefined ? {} : { tags: input.tags }),\n151\t      } as CardFrontmatter<T>\n152\t      const nextBody = input.body ?? card.body\n153\t      const stored = await this.storage.writeCard(\n154\t        this.columnPath(column),\n155\t        fileName,\n156\t        stringifyCard(nextFrontmatter, nextBody),\n157\t      )\n158\t      return this.toCard(column, fileName, stored.content, stored.createdAt, stored.updatedAt)\n159\t    })\n160\t  }\n161\t\n162\t  async moveCard(locator: CardLocator, target: { column: string }): Promise<Card<T>> {\n163\t    this.assertInitialized()\n164\t    const fromColumn = this.assertColumn(locator.column)\n165\t    const toColumn = this.assertColumn(target.column)\n166\t    validateCardId(locator.id)\n167\t    const fileName = toFileName(locator.id)\n168\t\n169\t    return this.enqueueWrite(async () => {\n170\t      const sourceCard = await this.readCard(fromColumn, fileName)\n171\t      const targetFileNames = await this.storage.listMarkdownFiles(this.columnPath(toColumn))\n172\t      if (targetFileNames.includes(fileName)) {\n173\t        throw new DuplicateCardError(\n174\t          `Card already exists in target column: ${toColumn}/${locator.id}`,\n175\t        )\n176\t      }\n177\t\n178\t      await this.storage.moveCard(\n179\t        { column: this.columnPath(fromColumn), fileName },\n180\t        { column: this.columnPath(toColumn), fileName },\n181\t      )\n182\t\n183\t      await this.normalizeColumnOrder(fromColumn)\n184\t      const targetCards = await this.listColumnCards(toColumn)\n185\t      const moved = targetCards.find((card) => card.id === locator.id)\n186\t      if (!moved) {\n187\t        throw new CardNotFoundError(`Moved card not found: ${toColumn}/${locator.id}`)\n188\t      }\n189\t\n190\t      const nextFrontmatter = {\n191\t        ...sourceCard.frontmatter,\n192\t        order: targetCards.length,\n193\t      }\n194\t      const stored = await this.storage.writeCard(\n195\t        this.columnPath(toColumn),\n196\t        fileName,\n197\t        stringifyCard(nextFrontmatter, moved.body),\n198\t      )\n199\t      return this.toCard(toColumn, fileName, stored.content, stored.createdAt, stored.updatedAt)\n200\t    })\n201\t  }\n202\t\n203\t  async reorderCard(locator: CardLocator, index: number): Promise<Card<T>[]> {\n204\t    this.assertInitialized()\n205\t    const column = this.assertColumn(locator.column)\n206\t    validateCardId(locator.id)\n207\t    const targetIndex = Math.max(0, Math.floor(index))\n208\t\n209\t    return this.enqueueWrite(async () => {\n210\t      const cards = await this.listColumnCards(column)\n211\t      const currentIndex = cards.findIndex((card) => card.id === locator.id)\n212\t      if (currentIndex === -1) {\n213\t        throw new CardNotFoundError(`Card not found: ${column}/${locator.id}`)\n214\t      }\n215\t\n216\t      const [card] = cards.splice(currentIndex, 1)\n217\t      cards.splice(Math.min(targetIndex, cards.length), 0, card)\n218\t      await this.writeOrderedCards(column, cards)\n219\t      return this.listColumnCards(column)\n220\t    })\n221\t  }\n222\t\n223\t  async deleteCard(locator: CardLocator): Promise<void> {\n224\t    this.assertInitialized()\n225\t    const column = this.assertColumn(locator.column)\n226\t    validateCardId(locator.id)\n227\t    const fileName = toFileName(locator.id)\n228\t\n229\t    return this.enqueueWrite(async () => {\n230\t      await this.storage.deleteCard(this.columnPath(column), fileName)\n231\t      await this.normalizeColumnOrder(column)\n232\t    })\n233\t  }\n234\t\n235\t  async searchCards(options: SearchCardsOptions): Promise<Card<T>[]> {\n236\t    this.assertInitialized()\n237\t    const cards = await this.listCards()\n238\t    const allowedColumns = options.columns\n239\t      ? new Set(options.columns.map((column) => this.assertColumn(column)))\n240\t      : undefined\n241\t    const requiredTags = options.tags ? new Set(options.tags) : undefined\n242\t    const filteredCards = cards.filter((card) => {\n243\t      if (allowedColumns && !allowedColumns.has(card.column)) {\n244\t        return false\n245\t      }\n246\t\n247\t      if (requiredTags && ![...requiredTags].every((tag) => card.frontmatter.tags.includes(tag))) {\n248\t        return false\n249\t      }\n250\t\n251\t      return true\n252\t    })\n253\t\n254\t    const fuse = new Fuse(filteredCards, {\n255\t      keys: [\"id\", \"frontmatter.title\", \"frontmatter.tags\", \"body\"],\n256\t      threshold: 0.35,\n257\t      ignoreLocation: true,\n258\t    })\n259\t\n260\t    return fuse.search(options.query, { limit: options.limit }).map((result) => result.item)\n261\t  }\n262\t\n263\t  private async listColumnCards(column: string): Promise<Card<T>[]> {\n264\t    const fileNames = await this.storage.listMarkdownFiles(this.columnPath(column))\n265\t    const cards = await Promise.all(fileNames.map((fileName) => this.readCard(column, fileName)))\n266\t    return cards.sort(\n267\t      (a, b) => a.frontmatter.order - b.frontmatter.order || a.id.localeCompare(b.id),\n268\t    )\n269\t  }\n270\t\n271\t  private async readCard(column: string, fileName: string): Promise<Card<T>> {\n272\t    const stored = await this.storage.readCard(this.columnPath(column), fileName)\n273\t    return this.toCard(column, fileName, stored.content, stored.createdAt, stored.updatedAt)\n274\t  }\n275\t\n276\t  private toCard(\n277\t    column: string,\n278\t    fileName: string,\n279\t    content: string,\n280\t    createdAt: Date,\n281\t    updatedAt: Date,\n282\t  ): Card<T> {\n283\t    const parsed = parseCardFrontmatter<T>(content, fileName)\n284\t    return {\n285\t      id: toId(fileName),\n286\t      fileName,\n287\t      column,\n288\t      frontmatter: parsed.frontmatter,\n289\t      body: parsed.body,\n290\t      createdAt,\n291\t      updatedAt,\n292\t    }\n293\t  }\n294\t\n295\t  private nextAvailableId(title: string, existingCards: Card<T>[]): string {\n296\t    const baseSlug = createSlug(title)\n297\t    const existingIds = new Set(existingCards.map((card) => card.id))\n298\t    if (!existingIds.has(baseSlug)) {\n299\t      return baseSlug\n300\t    }\n301\t\n302\t    for (let suffix = 2; suffix < Number.MAX_SAFE_INTEGER; suffix += 1) {\n303\t      const id = `${baseSlug}-${suffix}`\n304\t      if (!existingIds.has(id)) {\n305\t        return id\n306\t      }\n307\t    }\n308\t\n309\t    throw new DuplicateCardError(`Could not generate a unique slug for title: ${title}`)\n310\t  }\n311\t\n312\t  private async normalizeColumnOrder(column: string): Promise<void> {\n313\t    await this.writeOrderedCards(column, await this.listColumnCards(column))\n314\t  }\n315\t\n316\t  private async writeOrderedCards(column: string, cards: Card<T>[]): Promise<void> {\n317\t    await Promise.all(\n318\t      cards.map((card, index) => {\n319\t        const frontmatter = {\n320\t          ...card.frontmatter,\n321\t          order: index + 1,\n322\t        }\n323\t        return this.storage.writeCard(\n324\t          this.columnPath(column),\n325\t          card.fileName,\n326\t          stringifyCard(frontmatter, card.body),\n327\t        )\n328\t      }),\n329\t    )\n330\t  }\n331\t\n332\t  private assertColumn(column: string): string {\n333\t    if (!this.columns.includes(column)) {\n334\t      throw new ColumnNotFoundError(`Column is not defined: ${column}`)\n335\t    }\n336\t    return column\n337\t  }\n338\t\n339\t  private columnPath(column: string): string {\n340\t    return this.root ? path.join(this.root, column) : column\n341\t  }\n342\t\n343\t  private assertInitialized(): void {\n344\t    if (!this.initialized) {\n345\t      throw new Error(\"Kanbamd must be initialized with init() before use.\")\n346\t    }\n347\t  }\n348\t\n349\t  private enqueueWrite<R>(operation: () => Promise<R>): Promise<R> {\n350\t    const queued = this.writeQueue.then(operation, operation)\n351\t    this.writeQueue = queued.then(\n352\t      () => undefined,\n353\t      () => undefined,\n354\t    )\n355\t    return queued\n356\t  }\n357\t}\n358\t"}]},"parent_tool_use_id":"toolu_01XczoMQ5QRhXmt12Gb2jsAQ","session_id":"7e10c329-12dd-4922-8869-d58b7dccb0a3","uuid":"22af5064-a25f-45bf-820a-70d00115b29a","timestamp":"2026-05-03T16:56:25.194Z"}
