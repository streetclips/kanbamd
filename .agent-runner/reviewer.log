{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WL6ndVcysv6wGLXSSSKnpc","type":"tool_result","content":"1\timport path from \"node:path\"\n2\timport Fuse from \"fuse.js\"\n3\timport {\n4\t  CardNotFoundError,\n5\t  ColumnNotFoundError,\n6\t  DuplicateCardError,\n7\t  InvalidStorageConfigurationError,\n8\t} from \"./errors.js\"\n9\timport {\n10\t  createSlug,\n11\t  parseCardFrontmatter,\n12\t  stringifyCard,\n13\t  toFileName,\n14\t  toId,\n15\t  validateCardId,\n16\t  validateColumnName,\n17\t  validateExtraFrontmatter,\n18\t  validateTags,\n19\t  validateTitle,\n20\t} from \"./helpers.js\"\n21\timport { FilesystemStorage, MemoryStorage, type StorageAdapter } from \"./storage.js\"\n22\timport type {\n23\t  Card,\n24\t  CardFrontmatter,\n25\t  CardLocator,\n26\t  CreateCardInput,\n27\t  ExtraFrontmatter,\n28\t  KanbamdOptions,\n29\t  ListCardsOptions,\n30\t  SearchCardsOptions,\n31\t  UpdateCardInput,\n32\t} from \"./types.js\"\n33\t\n34\tconst defaultOrderStep = 1\n35\t\n36\texport class Kanbamd<T extends ExtraFrontmatter = ExtraFrontmatter> {\n37\t  private readonly root?: string\n38\t  private readonly columns: string[]\n39\t  private readonly createRoot: boolean\n40\t  private readonly createColumns: boolean\n41\t  private readonly storage: StorageAdapter\n42\t  private writeQueue = Promise.resolve()\n43\t  private initialized = false\n44\t\n45\t  constructor(options: KanbamdOptions) {\n46\t    const storageKind = options.storage ?? \"filesystem\"\n47\t    this.root = options.root\n48\t    this.columns = [...options.columns]\n49\t    this.createRoot = options.createRoot ?? false\n50\t    this.createColumns = options.createColumns ?? true\n51\t\n52\t    if (this.columns.length === 0) {\n53\t      throw new ColumnNotFoundError(\"At least one column must be defined.\")\n54\t    }\n55\t\n56\t    for (const column of this.columns) {\n57\t      validateColumnName(column)\n58\t    }\n59\t\n60\t    if (storageKind === \"filesystem\" && !this.r