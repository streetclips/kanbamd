{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TY4MmzRcweKdpMWGzmYt3M","type":"tool_result","content":"1\timport matter from \"gray-matter\"\n2\timport slugify from \"slugify\"\n3\timport { CardNotFoundError, InvalidFrontmatterError } from \"./errors.js\"\n4\timport type { BaseFrontmatter, CardFrontmatter, ExtraFrontmatter } from \"./types.js\"\n5\t\n6\tconst reservedFrontmatterKeys = new Set([\"title\", \"tags\", \"order\"])\n7\t\n8\texport function toFileName(id: string): string {\n9\t  return `${id.replace(/\\.md$/, \"\")}.md`\n10\t}\n11\t\n12\texport function toId(fileName: string): string {\n13\t  return fileName.replace(/\\.md$/, \"\")\n14\t}\n15\t\n16\texport function createSlug(title: string): string {\n17\t  const slug = slugify(title, {\n18\t    lower: true,\n19\t    strict: true,\n20\t    trim: true,\n21\t  })\n22\t  return slug || \"card\"\n23\t}\n24\t\n25\texport function validateColumnName(column: string): void {\n26\t  if (\n27\t    !column ||\n28\t    column.includes(\"/\") ||\n29\t    column.includes(\"\\\\\") ||\n30\t    column === \".\" ||\n31\t    column === \"..\"\n32\t  ) {\n33\t    throw new InvalidFrontmatterError(`Invalid column name: ${column}`)\n34\t  }\n35\t}\n36\t\n37\texport function validateCardId(id: string): void {\n38\t  if (\n39\t    !id ||\n40\t    id.includes(\"/\") ||\n41\t    id.includes(\"\\\\\") ||\n42\t    id === \".\" ||\n43\t    id === \"..\" ||\n44\t    id.endsWith(\".md\")\n45\t  ) {\n46\t    throw new CardNotFoundError(`Invalid card id: ${id}`)\n47\t  }\n48\t}\n49\t\n50\texport function validateTitle(title: string): void {\n51\t  if (typeof title !== \"string\" || title.trim() === \"\") {\n52\t    throw new InvalidFrontmatterError(\"Card title must be a non-empty string.\")\n53\t  }\n54\t}\n55\t\n56\texport function validateTags(tags: string[]): void {\n57\t  if (!Array.isArray(tags) || tags.some((tag) => typeof tag !== \"string\")) {\n58\t    throw new InvalidFrontmatterError(\"Card tags must be a string array.\")\n59\t  }\n60\t}\n61\t\n62\texport function validateExtraFrontmatter(frontmatter: ExtraFrontmatter | undefined): void {\n63\t  if (!frontmatter) {\n64\t    return\n65\t  }\n66\t\n67\t  for (const key of Object.keys(frontmatter)) {\n68\t    if (reservedFrontmatterKeys.has(key)) {\n69\t      throw new InvalidFrontmatterError(`Frontmatter key is reserved: ${key}`)\n70\t    }\n71\t  }\n72\t}\n73\t\n74\texport function parseCardFrontmatter<T extends ExtraFrontmatter>(\n75\t  content: string,\n76\t  fileName: string,\n77\t): { frontmatter: CardFrontmatter<T>; body: string } {\n78\t  const parsed = matter(content)\n79\t  assertBaseFrontmatter(parsed.data, fileName)\n80\t\n81\t  return {\n82\t    frontmatter: parsed.data as unknown as CardFrontmatter<T>,\n83\t    body: parsed.content.replace(/^\\n/, \"\"),\n84\t  }\n85\t}\n86\t\n87\texport function stringifyCard<T extends ExtraFrontmatter>(\n88\t  frontmatter: CardFrontmatter<T>,\n89\t  body: string,\n90\t): string {\n91\t  return matter.stringify(body ?? \"\", frontmatter)\n92\t}\n93\t\n94\texport function assertBaseFrontmatter(\n95\t  data: Record<string, unknown>,\n96\t  fileName: string,\n97\t): asserts data is BaseFrontmatter {\n98\t  if (typeof data.title !== \"string\" || data.title.trim() === \"\") {\n99\t    throw new InvalidFrontmatterError(`Card ${fileName} must have a non-empty string title.`)\n100\t  }\n101\t\n102\t  if (!Array.isArray(data.tags) || data.tags.some((tag) => typeof tag !== \"string\")) {\n103\t    throw new InvalidFrontmatterError(`Card ${fileName} must have a tags string array.`)\n104\t  }\n105\t\n106\t  if (typeof data.order !== \"number\" || !Number.isInteger(data.order) || data.order < 1) {\n107\t    throw new InvalidFrontmatterError(`Card ${fileName} must have a positive integer order.`)\n108\t  }\n109\t}\n110\t"}]},"parent_tool_use_id":"toolu_01XczoMQ5QRhXmt12Gb2jsAQ","session_id":"7e10c329-12dd-4922-8869-d58b7dccb0a3","uuid":"51eeb864-bd37-4d83-abd2-c219e83db996","ti