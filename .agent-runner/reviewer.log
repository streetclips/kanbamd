{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xz1xjAHGJubthHGVGWWMqJ","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\timport { createRequire } from \"node:module\"\n3\timport { existsSync } from \"node:fs\"\n4\timport { mkdir, readFile, readdir, writeFile } from \"node:fs/promises\"\n5\timport path from \"node:path\"\n6\timport process from \"node:process\"\n7\timport { ExitPromptError } from \"@inquirer/core\"\n8\timport { confirm, input, select } from \"@inquirer/prompts\"\n9\timport chalk from \"chalk\"\n10\timport { Command } from \"commander\"\n11\timport { Kanbamd } from \"./index.js\"\n12\timport type { Card } from \"./types.js\"\n13\t\n14\tconst _require = createRequire(import.meta.url)\n15\tconst { version } = _require(\"../package.json\") as { version: string }\n16\t\n17\tconst CONFIG_FILE = \".kanbamd.json\"\n18\t\n19\ttype Config = {\n20\t  root: string\n21\t  columns: string[]\n22\t}\n23\t\n24\tasync function findConfigPath(startDir: string): Promise<string | null> {\n25\t  let dir = startDir\n26\t  while (true) {\n27\t    const p = path.join(dir, CONFIG_FILE)\n28\t    if (existsSync(p)) return p\n29\t    const parent = path.dirname(dir)\n30\t    if (parent === dir) return null\n31\t    dir = parent\n32\t  }\n33\t}\n34\t\n35\tasync function detectColumns(dir: string): Promise<string[]> {\n36\t  try {\n37\t    const entries = await readdir(dir, { withFileTypes: true })\n38\t    return entries\n39\t      .filter((e) => e.isDirectory() && !e.name.startsWith(\".\"))\n40\t      .map((e) => e.name)\n41\t      .sort()\n42\t  } catch {\n43\t    return []\n44\t  }\n45\t}\n46\t\n47\tasync function resolveBoard(opts: {\n48\t  root?: string\n49\t  columns?: string\n50\t}): Promise<{ board: Kanbamd; config: Config }> {\n51\t  let config: Config\n52\t\n53\t  if (opts.root || opts.columns) {\n54\t    const root = path.resolve(opts.root ?? process.cwd())\n55\t    const columns = opts.columns\n56\t      ? opts.columns.split(\",\").map((c) => c.trim()).filter(Boolean)\n57\t      : await detectColumns(root)\n58\t    config = { root, columns }\n59\t  } else {\n60\t    const configPath = await findConfigPath(process.cwd())\n61\t    if (configPath) {\n62\t      const configDir = path.dirname(configPath)\n63\t      const raw = JSON.parse(await readFile(configPath, \"utf-8\")) as Config\n64\t      config = { ...raw, root: path.resolve(configDir, raw.root) }\n65\t    } else {\n66\t      const root = process.cwd()\n67\t      const columns = await detectColumns(root)\n68\t      if (columns.length === 0) {\n69\t        console.error(\n70\t          chalk.red(\"No board found. Run `kanbamd init` to create one.\"),\n71\t        )\n72\t        process.exit(1)\n73\t      }\n74\t      config = { root, columns }\n75\t    }\n76\t  }\n77\t\n78\t  if (config.columns.length === 0) {\n79\t    console.error(\n80\t      chalk.red(\"No columns found. Specify --columns or run `kanbamd init`.\"),\n81\t    )\n82\t    process.exit(1)\n83\t  }\n84\t\n85\t  const board = new Kanbamd({\n86\t    root: config.root,\n87\t    columns: config.columns,\n88\t    createRoot: false,\n89\t    createColumns: false,\n90\t  })\n91\t  await board.init()\n92\t  return { board, config }\n93\t}\n94\t\n95\tfunction printCardLine(card: Card): void {\n96\t  const col = chalk.dim(`[${card.column}]`)\n97\t  const title = chalk.bold(card.frontmatter.title)\n98\t  const id = chalk.dim(`#${card.id}`)\n99\t  const order = chalk.dim(`${card.frontmatter.order}.`)\n100\t  const tags =\n101\t    card.frontmatter.tags.length > 0\n102\t      ? \" \" + card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \")\n103\t      : \"\"\n104\t  console.log(`  ${order} ${col} ${title} ${id}${tags}`)\n105\t}\n106\t\n107\tfunction printCardDetail(card: Card): void {\n108\t  console.log()\n109\t  console.log(chalk.bold.cyan(`  ${card.frontmatter.title}`))\n110\t  console.log(chalk.dim(`  ID:      `) + card.id)\n111\t  console.log(chalk.dim(`  Column:  `) + chalk.cyan(card.column))\n112\t  console.log(chalk.dim(`  Order:   `) + card.frontmatter.order)\n113\t  if (card.frontmatter.tags.length > 0) {\n114\t    console.log(\n115\t      chalk.dim(`  Tags:    `) +\n116\t        card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \"),\n117\t    )\n118\t  }\n119\t  console.log(\n120\t    chalk.dim(`  Created: `) + card.createdAt.toLocaleDateString(),\n121\t  )\n122\t  console.log(\n123\t    chalk.dim(`  Updated: `) + card.updatedAt.toLocaleDateString(),\n124\t  )\n125\t  if (card.body.trim()) {\n126\t    console.log()\n127\t    for (const line of card.body.trim().split(\"\\n\")) {\n128\t      console.log(`  ${chalk.white(line)}`)\n129\t    }\n130\t  }\n131\t  console.log()\n132\t}\n133\t\n134\tfunction cardChoice(card: Card): { name: string; value: Card } {\n135\t  const tags =\n136\t    card.frontmatter.tags.length > 0\n137\t      ? \" \" + card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \")\n138\t      : \"\"\n139\t  return {\n140\t    name: `${chalk.dim(`[${card.column}]`)} ${card.frontmatter.title} ${chalk.dim(`#${card.id}`)}${tags}`,\n141\t    value: card,\n142\t  }\n143\t}\n144\t\n145\tasync function run(fn: () => Promise<void>): Promise<void> {\n146\t  try {\n147\t    await fn()\n148\t  } catch (error) {\n149\t    if (error instanceof ExitPromptError) {\n150\t      console.log(chalk.dim(\"\\nCancelled.\"))\n151\t      process.exit(0)\n152\t    }\n153\t    const msg = error instanceof Error ? error.message : String(error)\n154\t    console.error(chalk.red(\"Error:\"), msg)\n155\t    process.exit(1)\n156\t  }\n157\t}\n158\t\n159\tconst program = new Command()\n160\t  .name(\"kanbamd\")\n161\t  .description(\"Manage Kanban boards backed by Markdown files\")\n162\t  .version(version)\n163\t  .option(\"--root <path>\", \"board root directory\")\n164\t  .option(\"--columns <cols>\", \"comma-separated column names\")\n165\t\n166\t// ── init ──────────────────────────────────────────────────────────────────────\n167\t\n168\tprogram\n169\t  .command(\"init\")\n170\t  .description(\"Initialize a new Kanban board in the current directory\")\n171\t  .option(\"--root <path>\", \"board root (default: current directory)\")\n172\t  .option(\n173\t    \"--columns <cols>\",\n174\t    \"comma-separated column names (default: todo,doing,done)\",\n175\t  )\n176\t  .action(async (opts: { root?: string; columns?: string }) =>\n177\t    run(async () => {\n178\t      const root = path.resolve(opts.root ?? process.cwd())\n179\t      const columnsRaw = opts.columns ?? \"todo,doing,done\"\n180\t      const columns = columnsRaw\n181\t        .split(\",\")\n182\t        .map((c) => c.trim())\n183\t        .filter(Boolean)\n184\t\n185\t      const configPath = path.join(process.cwd(), CONFIG_FILE)\n186\t      const relativeRoot = path.relative(process.cwd(), root) || \".\"\n187\t      const configData: Config = { root: relativeRoot, columns }\n188\t\n189\t      await writeFile(\n190\t        configPath,\n191\t        JSON.stringify(configData, null, 2) + \"\\n\",\n192\t        \"utf-8\",\n193\t      )\n194\t      console.log(chalk.green(`✓ Config written to ${CONFIG_FILE}`))\n195\t\n196\t      for (const col of columns) {\n197\t        await mkdir(path.join(root, col), { recursive: true })\n198\t        console.log(chalk.green(`✓ Created column: ${col}`))\n199\t      }\n200\t\n201\t      console.log(chalk.bold(\"\\nBoard initialized!\"))\n202\t      console.log(`  Root:    ${chalk.cyan(relativeRoot)}`)\n203\t      console.log(`  Columns: ${chalk.cyan(columns.join(\", \"))}`)\n204\t      console.log()\n205\t    }),\n206\t  )\n207\t\n208\t// ── columns ───────────────────────────────────────────────────────────────────\n209\t\n210\tprogram\n211\t  .command(\"columns\")\n212\t  .description(\"List all columns with card counts\")\n213\t  .action(async () =>\n214\t    run(async () => {\n215\t      const { board, config } = await resolveBoard(program.opts())\n216\t      console.log(chalk.bold(\"\\nColumns:\"))\n217\t      for (const col of config.columns) {\n218\t        const cards = await board.listCards({ column: col })\n219\t        const n = cards.length\n220\t        console.log(\n221\t          `  ${chalk.cyan(col)} ${chalk.dim(`(${n} card${n !== 1 ? \"s\" : \"\"})`)}`,\n222\t        )\n223\t      }\n224\t      console.log()\n225\t    }),\n226\t  )\n227\t\n228\t// ── list ──────────────────────────────────────────────────────────────────────\n229\t\n230\tprogram\n231\t  .command(\"list\")\n232\t  .description(\"List cards, optionally filtered by column\")\n233\t  .option(\"-c, --column <col>\", \"filter by column\")\n234\t  .action(async (opts: { column?: string }) =>\n235\t    run(async () => {\n236\t      const { board } = await resolveBoard(program.opts())\n237\t      const cards = await board.listCards(opts.column ? { column: opts.column } : {})\n238\t\n239\t      if (cards.length === 0) {\n240\t        console.log(chalk.dim(\"No cards found.\"))\n241\t        return\n242\t      }\n243\t\n244\t      const byColumn: Record<string, Card[]> = {}\n245\t      for (const card of cards) {\n246\t        ;(byColumn[card.column] ??= []).push(card)\n247\t      }\n248\t\n249\t      for (const [col, colCards] of Object.entries(byColumn)) {\n250\t        const n = colCards.length\n251\t        console.log(\n252\t          chalk.bold(\n253\t            `\\n── ${chalk.cyan(col)} ${chalk.dim(`(${n} card${n !== 1 ? \"s\" : \"\"})`)} ──`,\n254\t          ),\n255\t        )\n256\t        for (const card of colCards) {\n257\t          printCardLine(card)\n258\t        }\n259\t      }\n260\t      console.log()\n261\t    }),\n262\t  )\n263\t\n264\t// ── add ───────────────────────────────────────────────────────────────────────\n265\t\n266\tprogram\n267\t  .command(\"add\")\n268\t  .description(\"Add a new card interactively\")\n269\t  .action(async () =>\n270\t    run(async () => {\n271\t      const { board, config } = await resolveBoard(program.opts())\n272\t\n273\t      const column =\n274\t        config.columns.length === 1\n275\t          ? config.columns[0]\n276\t          : await select({\n277\t              message: \"Select column:\",\n278\t              choices: config.columns.map((c) => ({\n279\t                name: chalk.cyan(c),\n280\t                value: c,\n281\t              })),\n282\t            })\n283\t\n284\t      const title = await input({\n285\t        message: \"Title:\",\n286\t        validate: (v) => (v.trim().length > 0 ? true : \"Title is required\"),\n287\t      })\n288\t\n289\t      const bodyRaw = await input({\n290\t        message: \"Body (optional):\",\n291\t      })\n292\t\n293\t      const tagsRaw = await input({\n294\t        message: \"Tags (comma-separated, optional):\",\n295\t      })\n296\t      const tags = tagsRaw.trim()\n297\t        ? tagsRaw\n298\t            .split(\",\")\n299\t            .map((t) => t.trim())\n300\t            .filter(Boolean)\n301\t        : []\n302\t\n303\t      const orderRaw = await input({\n304\t        message: \"Order (leave empty to place last):\",\n305\t        validate: (v) =>\n306\t          !v.trim() || /^\\d+$/.test(v.trim())\n307\t            ? true\n308\t            : \"Must be a positive integer\",\n309\t      })\n310\t\n311\t      const card = await board.createCard(column, {\n312\t        title: title.trim(),\n313\t        body: bodyRaw.trim(),\n314\t        tags,\n315\t      })\n316\t\n317\t      if (orderRaw.trim()) {\n318\t        const targetIndex = Math.max(0, Number.parseInt(orderRaw.trim(), 10) - 1)\n319\t        await board.reorderCard({ column, id: card.id }, targetIndex)\n320\t        const updated = await board.getCard({ column, id: card.id })\n321\t        console.log(chalk.green(\"\\n✓ Card created:\"))\n322\t        printCardLine(updated)\n323\t      } else {\n324\t        console.log(chalk.green(\"\\n✓ Card created:\"))\n325\t        printCardLine(card)\n326\t      }\n327\t      console.log()\n328\t    }),\n329\t  )\n330\t\n331\t// ── view ──────────────────────────────────────────────────────────────────────\n332\t\n333\tprogram\n334\t  .command(\"view [id]\")\n335\t  .description(\"View a card in detail (interactive if no ID given)\")\n336\t  .option(\"-c, --column <col>\", \"column of the card\")\n337\t  .action(async (id: string | undefined, opts: { column?: string }) =>\n338\t    run(async () => {\n339\t      const { board } = await resolveBoard(program.opts())\n340\t\n341\t      let cardId = id\n342\t      let column = opts.column\n343\t\n344\t      if (!cardId) {\n345\t        const cards = await board.listCards(column ? { column } : {})\n346\t        if (cards.length === 0) {\n347\t          console.log(chalk.dim(\"No cards found.\"))\n348\t          return\n349\t        }\n350\t        const chosen = await select({\n351\t          message: \"Select card:\",\n352\t          choices: cards.map(cardChoice),\n353\t        })\n354\t        cardId = chosen.id\n355\t        column = chosen.column\n356\t      }\n357\t\n358\t      if (!column) {\n359\t        const cards = await board.listCards()\n360\t        const found = cards.find((c) => c.id === cardId)\n361\t        if (!found) {\n362\t          console.error(chalk.red(`Card not found: ${cardId}`))\n363\t          process.exit(1)\n364\t        }\n365\t        column = found.column\n366\t      }\n367\t\n368\t      const card = await board.getCard({ column, id: cardId })\n369\t      printCardDetail(card)\n370\t    }),\n371\t  )\n372\t\n373\t// ── move ──────────────────────────────────────────────────────────────────────\n374\t\n375\tprogram\n376\t  .command(\"move [id]\")\n377\t  .description(\"Move a card to another column (interactive)\")\n378\t  .option(\"-c, --column <col>\", \"current column of the card\")\n379\t  .option(\"--to <col>\", \"target column\")\n380\t  .action(\n381\t    async (\n382\t      id: string | undefined,\n383\t      opts: { column?: string; to?: string },\n384\t    ) =>\n385\t      run(async () => {\n386\t        const { board, config } = await resolveBoard(program.opts())\n387\t\n388\t        let cardId = id\n389\t        let fromColumn = opts.column\n390\t\n391\t        if (!cardId) {\n392\t          const cards = await board.listCards(fromColumn ? { column: fromColumn } : {})\n393\t          if (cards.length === 0) {\n394\t            console.log(chalk.dim(\"No cards found.\"))\n395\t            return\n396\t          }\n397\t          const chosen = await select({\n398\t            message: \"Select card to move:\",\n399\t            choices: cards.map(cardChoice),\n400\t          })\n401\t          cardId = chosen.id\n402\t          fromColumn = chosen.column\n403\t        }\n404\t\n405\t        if (!fromColumn) {\n406\t          const cards = await board.listCards()\n407\t          const found = cards.find((c) => c.id === cardId)\n408\t          if (!found) {\n409\t            console.error(chalk.red(`Card not found: ${cardId}`))\n410\t            process.exit(1)\n411\t          }\n412\t          fromColumn = found.column\n413\t        }\n414\t\n415\t        const targetCols = config.columns.filter((c) => c !== fromColumn)\n416\t        if (targetCols.length === 0) {\n417\t          console.error(chalk.red(\"No other columns to move to.\"))\n418\t          process.exit(1)\n419\t        }\n420\t\n421\t        const toColumn =\n422\t          opts.to ??\n423\t          (targetCols.length === 1\n424\t            ? targetCols[0]\n425\t            : await select({\n426\t                message: \"Move to column:\",\n427\t                choices: targetCols.map((c) => ({\n428\t                  name: chalk.cyan(c),\n429\t                  value: c,\n430\t                })),\n431\t              }))\n432\t\n433\t        const card = await board.moveCard(\n434\t          { column: fromColumn, id: cardId },\n435\t          { column: toColumn },\n436\t        )\n437\t        console.log(chalk.green(`\\n✓ Moved to ${chalk.cyan(toColumn)}:`))\n438\t        printCardLine(card)\n439\t        console.log()\n440\t      }),\n441\t  )\n442\t\n443\t// ── delete ────────────────────────────────────────────────────────────────────\n444\t\n445\tprogram\n446\t  .command(\"delete [id]\")\n447\t  .description(\"Delete a card (interactive)\")\n448\t  .option(\"-c, --column <col>\", \"column of the card\")\n449\t  .action(async (id: string | undefined, opts: { column?: string }) =>\n450\t    run(async () => {\n451\t      const { board } = await resolveBoard(program.opts())\n452\t\n453\t      let cardId = id\n454\t      let column = opts.column\n455\t\n456\t      if (!cardId) {\n457\t        const cards = await board.listCards(column ? { column } : {})\n458\t        if (cards.length === 0) {\n459\t          console.log(chalk.dim(\"No cards found.\"))\n460\t          return\n461\t        }\n462\t        const chosen = await select({\n463\t          message: \"Select card to delete:\",\n464\t          choices: cards.map(cardChoice),\n465\t        })\n466\t        cardId = chosen.id\n467\t        column = chosen.column\n468\t      }\n469\t\n470\t      if (!column) {\n471\t        const cards = await board.listCards()\n472\t        const found = cards.find((c) => c.id === cardId)\n473\t        if (!found) {\n474\t          console.error(chalk.red(`Card not found: ${cardId}`))\n475\t          process.exit(1)\n476\t        }\n477\t        column = found.column\n478\t      }\n479\t\n480\t      const card = await board.getCard({ column, id: cardId })\n481\t      printCardDetail(card)\n482\t\n483\t      const ok = await confirm({\n484\t        message: chalk.red(\"Delete this card?\"),\n485\t        default: false,\n486\t      })\n487\t\n488\t      if (!ok) {\n489\t        console.log(chalk.dim(\"Cancelled.\"))\n490\t        return\n491\t      }\n492\t\n493\t      await board.deleteCard({ column, id: cardId })\n494\t      console.log(chalk.green(`\\n✓ Deleted: ${cardId}`))\n495\t      console.log()\n496\t    }),\n497\t  )\n498\t\n499\t// ── search ────────────────────────────────────────────────────────────────────\n500\t\n501\tprogram\n502\t  .command(\"search <query>\")\n503\t  .description(\"Search cards with fuzzy matching\")\n504\t  .option(\"-c, --column <cols>\", \"filter by column(s), comma-separated\")\n505\t  .option(\"-t, --tags <tags>\", \"filter by tag(s), comma-separated\")\n506\t  .option(\"-l, --limit <n>\", \"maximum number of results\", \"10\")\n507\t  .action(\n508\t    async (\n509\t      query: string,\n510\t      opts: { column?: string; tags?: string; limit: string },\n511\t    ) =>\n512\t      run(async () => {\n513\t        const { board } = await resolveBoard(program.opts())\n514\t\n515\t        const results = await board.searchCards({\n516\t          query,\n517\t          limit: Number.parseInt(opts.limit, 10),\n518\t          ...(opts.column\n519\t            ? {\n520\t                columns: opts.column\n521\t                  .split(\",\")\n522\t                  .map((c) => c.trim())\n523\t                  .filter(Boolean),\n524\t              }\n525\t            : {}),\n526\t          ...(opts.tags\n527\t            ? {\n528\t                tags: opts.tags\n529\t                  .split(\",\")\n530\t                  .map((t) => t.trim())\n531\t                  .filter(Boolean),\n532\t              }\n533\t            : {}),\n534\t        })\n535\t\n536\t        if (results.length === 0) {\n537\t          console.log(chalk.dim(`\\nNo results for \"${query}\".`))\n538\t          return\n539\t        }\n540\t\n541\t        console.log(\n542\t          chalk.bold(`\\nResults for \"${chalk.cyan(query)}\" (${results.length}):`),\n543\t        )\n544\t        for (const card of results) {\n545\t          printCardLine(card)\n546\t        }\n547\t        console.log()\n548\t      }),\n549\t  )\n550\t\n551\tprogram.parse()\n552\t"}]},"parent_tool_use_id":null,"session_id":"7e10c329-12dd-4922-8869-d58b7dccb0a3","uuid":"fe11ff77-0865-4ebd-acbf-c1e14c87304e","timestamp":"2026-05-03T16:57:21.417Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/cli.ts","content":"#!/usr/bin/env node\nimport { createRequire } from \"node:module\"\nimport { existsSync } from \"node:fs\"\nimport { mkdir, readFile, readdir, writeFile } from \"node:fs/promises\"\nimport path from \"node:path\"\nimport process from \"node:process\"\nimport { ExitPromptError } from \"@inquirer/core\"\nimport { confirm, input, select } from \"@inquirer/prompts\"\nimport chalk from \"chalk\"\nimport { Command } from \"commander\"\nimport { Kanbamd } from \"./index.js\"\nimport type { Card } from \"./types.js\"\n\nconst _require = createRequire(import.meta.url)\nconst { version } = _require(\"../package.json\") as { version: string }\n\nconst CONFIG_FILE = \".kanbamd.json\"\n\ntype Config = {\n  root: string\n  columns: string[]\n}\n\nasync function findConfigPath(startDir: string): Promise<string | null> {\n  let dir = startDir\n  while (true) {\n    const p = path.join(dir, CONFIG_FILE)\n    if (existsSync(p)) return p\n    const parent = path.dirname(dir)\n    if (parent === dir) return null\n    dir = parent\n  }\n}\n\nasync function detectColumns(dir: string): Promise<string[]> {\n  try {\n    const entries = await readdir(dir, { withFileTypes: true })\n    return entries\n      .filter((e) => e.isDirectory() && !e.name.startsWith(\".\"))\n      .map((e) => e.name)\n      .sort()\n  } catch {\n    return []\n  }\n}\n\nasync function resolveBoard(opts: {\n  root?: string\n  columns?: string\n}): Promise<{ board: Kanbamd; config: Config }> {\n  let config: Config\n\n  if (opts.root || opts.columns) {\n    const root = path.resolve(opts.root ?? process.cwd())\n    const columns = opts.columns\n      ? opts.columns.split(\",\").map((c) => c.trim()).filter(Boolean)\n      : await detectColumns(root)\n    config = { root, columns }\n  } else {\n    const configPath = await findConfigPath(process.cwd())\n    if (configPath) {\n      const configDir = path.dirname(configPath)\n      const raw = JSON.parse(await readFile(configPath, \"utf-8\")) as Config\n      config = { ...raw, root: path.resolve(configDir, raw.root) }\n    } else {\n      const root = process.cwd()\n      const columns = await detectColumns(root)\n      if (columns.length === 0) {\n        console.error(\n          chalk.red(\"No board found. Run `kanbamd init` to create one.\"),\n        )\n        process.exit(1)\n      }\n      config = { root, columns }\n    }\n  }\n\n  if (config.columns.length === 0) {\n    console.error(\n      chalk.red(\"No columns found. Specify --columns or run `kanbamd init`.\"),\n    )\n    process.exit(1)\n  }\n\n  const board = new Kanbamd({\n    root: config.root,\n    columns: config.columns,\n    createRoot: false,\n    createColumns: false,\n  })\n  await board.init()\n  return { board, config }\n}\n\nfunction printCardLine(card: Card): void {\n  const col = chalk.dim(`[${card.column}]`)\n  const title = chalk.bold(card.frontmatter.title)\n  const id = chalk.dim(`#${card.id}`)\n  const order = chalk.dim(`${card.frontmatter.order}.`)\n  const tags =\n    card.frontmatter.tags.length > 0\n      ? \" \" + card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \")\n      : \"\"\n  console.log(`  ${order} ${col} ${title} ${id}${tags}`)\n}\n\nfunction printCardDetail(card: Card): void {\n  console.log()\n  console.log(chalk.bold.cyan(`  ${card.frontmatter.title}`))\n  console.log(chalk.dim(`  ID:      `) + card.id)\n  console.log(chalk.dim(`  Column:  `) + chalk.cyan(card.column))\n  console.log(chalk.dim(`  Order:   `) + card.frontmatter.order)\n  if (card.frontmatter.tags.length > 0) {\n    console.log(\n      chalk.dim(`  Tags:    `) +\n        card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \"),\n    )\n  }\n  console.log(\n    chalk.dim(`  Created: `) + card.createdAt.toLocaleDateString(),\n  )\n  console.log(\n    chalk.dim(`  Updated: `) + card.updatedAt.toLocaleDateString(),\n  )\n  if (card.body.trim()) {\n    console.log()\n    for (const line of card.body.trim().split(\"\\n\")) {\n      console.log(`  ${chalk.white(line)}`)\n    }\n  }\n  console.log()\n}\n\nfunction cardChoice(card: Card): { name: string; value: Card } {\n  const tags =\n    card.frontmatter.tags.length > 0\n      ? \" \" + card.frontmatter.tags.map((t) => chalk.yellow(`#${t}`)).join(\" \")\n      : \"\"\n  return {\n    name: `${chalk.dim(`[${card.column}]`)} ${card.frontmatter.title} ${chalk.dim(`#${card.id}`)}${tags}`,\n    value: card,\n  }\n}\n\nasync function run(fn: () => Promise<void>): Promise<void> {\n  try {\n    await fn()\n  } catch (error) {\n    if (error instanceof ExitPromptError) {\n      console.log(chalk.dim(\"\\nCancelled.\"))\n      process.exit(0)\n    }\n    const msg = error instanceof Error ? error.message : String(error)\n    console.error(chalk.red(\"Error:\"), msg)\n    process.exit(1)\n  }\n}\n\nconst program = new Command()\n  .name(\"kanbamd\")\n  .description(\"Manage Kanban boards backed by Markdown files\")\n  .version(version)\n  .option(\"--root <path>\", \"board root directory\")\n  .option(\"--columns <cols>\", \"comma-separated column names\")\n\n// ── init ──────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"init\")\n  .description(\"Initialize a new Kanban board in the current directory\")\n  .option(\"--root <path>\", \"board root (default: current directory)\")\n  .option(\n    \"--columns <cols>\",\n    \"comma-separated column names (default: todo,doing,done)\",\n  )\n  .action(async (opts: { root?: string; columns?: string }) =>\n    run(async () => {\n      const root = path.resolve(opts.root ?? process.cwd())\n      const columnsRaw = opts.columns ?? \"todo,doing,done\"\n      const columns = columnsRaw\n        .split(\",\")\n        .map((c) => c.trim())\n        .filter(Boolean)\n\n      const configPath = path.join(process.cwd(), CONFIG_FILE)\n      const relativeRoot = path.relative(process.cwd(), root) || \".\"\n      const configData: Config = { root: relativeRoot, columns }\n\n      await writeFile(\n        configPath,\n        JSON.stringify(configData, null, 2) + \"\\n\",\n        \"utf-8\",\n      )\n      console.log(chalk.green(`✓ Config written to ${CONFIG_FILE}`))\n\n      for (const col of columns) {\n        await mkdir(path.join(root, col), { recursive: true })\n        console.log(chalk.green(`✓ Created column: ${col}`))\n      }\n\n      console.log(chalk.bold(\"\\nBoard initialized!\"))\n      console.log(`  Root:    ${chalk.cyan(relativeRoot)}`)\n      console.log(`  Columns: ${chalk.cyan(columns.join(\", \"))}`)\n      console.log()\n    }),\n  )\n\n// ── columns ───────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"columns\")\n  .description(\"List all columns with card counts\")\n  .action(async () =>\n    run(async () => {\n      const { board, config } = await resolveBoard(program.opts())\n      console.log(chalk.bold(\"\\nColumns:\"))\n      for (const col of config.columns) {\n        const cards = await board.listCards({ column: col })\n        const n = cards.length\n        console.log(\n          `  ${chalk.cyan(col)} ${chalk.dim(`(${n} card${n !== 1 ? \"s\" : \"\"})`)}`,\n        )\n      }\n      console.log()\n    }),\n  )\n\n// ── list ──────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"list\")\n  .description(\"List cards, optionally filtered by column\")\n  .option(\"-c, --column <col>\", \"filter by column\")\n  .action(async (opts: { column?: string }) =>\n    run(async () => {\n      const { board } = await resolveBoard(program.opts())\n      const cards = await board.listCards(opts.column ? { column: opts.column } : {})\n\n      if (cards.length === 0) {\n        console.log(chalk.dim(\"No cards found.\"))\n        return\n      }\n\n      const byColumn: Record<string, Card[]> = {}\n      for (const card of cards) {\n        ;(byColumn[card.column] ??= []).push(card)\n      }\n\n      for (const [col, colCards] of Object.entries(byColumn)) {\n        const n = colCards.length\n        console.log(\n          chalk.bold(\n            `\\n── ${chalk.cyan(col)} ${chalk.dim(`(${n} card${n !== 1 ? \"s\" : \"\"})`)} ──`,\n          ),\n        )\n        for (const card of colCards) {\n          printCardLine(card)\n        }\n      }\n      console.log()\n    }),\n  )\n\n// ── add ───────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"add\")\n  .description(\"Add a new card interactively\")\n  .action(async () =>\n    run(async () => {\n      const { board, config } = await resolveBoard(program.opts())\n\n      const column =\n        config.columns.length === 1\n          ? config.columns[0]\n          : await select({\n              message: \"Select column:\",\n              choices: config.columns.map((c) => ({\n                name: chalk.cyan(c),\n                value: c,\n              })),\n            })\n\n      const title = await input({\n        message: \"Title:\",\n        validate: (v) => (v.trim().length > 0 ? true : \"Title is required\"),\n      })\n\n      const bodyRaw = await input({\n        message: \"Body (optional):\",\n      })\n\n      const tagsRaw = await input({\n        message: \"Tags (comma-separated, optional):\",\n      })\n      const tags = tagsRaw.trim()\n        ? tagsRaw\n            .split(\",\")\n            .map((t) => t.trim())\n            .filter(Boolean)\n        : []\n\n      const orderRaw = await input({\n        message: \"Order (leave empty to place last):\",\n        validate: (v) =>\n          !v.trim() || /^\\d+$/.test(v.trim())\n            ? true\n            : \"Must be a positive integer\",\n      })\n\n      const card = await board.createCard(column, {\n        title: title.trim(),\n        body: bodyRaw.trim(),\n        tags,\n      })\n\n      if (orderRaw.trim()) {\n        const targetIndex = Math.max(0, Number.parseInt(orderRaw.trim(), 10) - 1)\n        await board.reorderCard({ column, id: card.id }, targetIndex)\n        const updated = await board.getCard({ column, id: card.id })\n        console.log(chalk.green(\"\\n✓ Card created:\"))\n        printCardLine(updated)\n      } else {\n        console.log(chalk.green(\"\\n✓ Card created:\"))\n        printCardLine(card)\n      }\n      console.log()\n    }),\n  )\n\n// ── view ──────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"view [id]\")\n  .description(\"View a card in detail (interactive if no ID given)\")\n  .option(\"-c, --column <col>\", \"column of the card\")\n  .action(async (id: string | undefined, opts: { column?: string }) =>\n    run(async () => {\n      const { board } = await resolveBoard(program.opts())\n\n      let cardId = id\n      let column = opts.column\n\n      if (!cardId) {\n        const cards = await board.listCards(column ? { column } : {})\n        if (cards.length === 0) {\n          console.log(chalk.dim(\"No cards found.\"))\n          return\n        }\n        const chosen = await select({\n          message: \"Select card:\",\n          choices: cards.map(cardChoice),\n        })\n        cardId = chosen.id\n        column = chosen.column\n      }\n\n      if (!column) {\n        const cards = await board.listCards()\n        const found = cards.find((c) => c.id === cardId)\n        if (!found) {\n          console.error(chalk.red(`Card not found: ${cardId}`))\n          process.exit(1)\n        }\n        column = found.column\n      }\n\n      const card = await board.getCard({ column, id: cardId })\n      printCardDetail(card)\n    }),\n  )\n\n// ── move ──────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"move [id]\")\n  .description(\"Move a card to another column (interactive)\")\n  .option(\"-c, --column <col>\", \"current column of the card\")\n  .option(\"--to <col>\", \"target column\")\n  .action(\n    async (\n      id: string | undefined,\n      opts: { column?: string; to?: string },\n    ) =>\n      run(async () => {\n        const { board, config } = await resolveBoard(program.opts())\n\n        let cardId = id\n        let fromColumn = opts.column\n\n        if (!cardId) {\n          const cards = await board.listCards(fromColumn ? { column: fromColumn } : {})\n          if (cards.length === 0) {\n            console.log(chalk.dim(\"No cards found.\"))\n            return\n          }\n          const chosen = await select({\n            message: \"Select card to move:\",\n            choices: cards.map(cardChoice),\n          })\n          cardId = chosen.id\n          fromColumn = chosen.column\n        }\n\n        if (!fromColumn) {\n          const cards = await board.listCards()\n          const found = cards.find((c) => c.id === cardId)\n          if (!found) {\n            console.error(chalk.red(`Card not found: ${cardId}`))\n            process.exit(1)\n          }\n          fromColumn = found.column\n        }\n\n        const targetCols = config.columns.filter((c) => c !== fromColumn)\n        if (targetCols.length === 0) {\n          console.error(chalk.red(\"No other columns to move to.\"))\n          process.exit(1)\n        }\n\n        const toColumn =\n          opts.to ??\n          (targetCols.length === 1\n            ? targetCols[0]\n            : await select({\n                message: \"Move to column:\",\n                choices: targetCols.map((c) => ({\n                  name: chalk.cyan(c),\n                  value: c,\n                })),\n              }))\n\n        const card = await board.moveCard(\n          { column: fromColumn, id: cardId },\n          { column: toColumn },\n        )\n        console.log(chalk.green(`\\n✓ Moved to ${chalk.cyan(toColumn)}:`))\n        printCardLine(card)\n        console.log()\n      }),\n  )\n\n// ── delete ────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"delete [id]\")\n  .description(\"Delete a card (interactive)\")\n  .option(\"-c, --column <col>\", \"column of the card\")\n  .action(async (id: string | undefined, opts: { column?: string }) =>\n    run(async () => {\n      const { board } = await resolveBoard(program.opts())\n\n      let cardId = id\n      let column = opts.column\n\n      if (!cardId) {\n        const cards = await board.listCards(column ? { column } : {})\n        if (cards.length === 0) {\n          console.log(chalk.dim(\"No cards found.\"))\n          return\n        }\n        const chosen = await select({\n          message: \"Select card to delete:\",\n          choices: cards.map(cardChoice),\n        })\n        cardId = chosen.id\n        column = chosen.column\n      }\n\n      if (!column) {\n        const cards = await board.listCards()\n        const found = cards.find((c) => c.id === cardId)\n        if (!found) {\n          console.error(chalk.red(`Card not found: ${cardId}`))\n          process.exit(1)\n        }\n        column = found.column\n      }\n\n      const card = await board.getCard({ column, id: cardId })\n      printCardDetail(card)\n\n      const ok = await confirm({\n        message: chalk.red(\"Delete this card?\"),\n        default: false,\n      })\n\n      if (!ok) {\n        console.log(chalk.dim(\"Cancelled.\"))\n        return\n      }\n\n      await board.deleteCard({ column, id: cardId })\n      console.log(chalk.green(`\\n✓ Deleted: ${cardId}`))\n      console.log()\n    }),\n  )\n\n// ── search ────────────────────────────────────────────────────────────────────\n\nprogram\n  .command(\"search <query>\")\n  .description(\"Search cards with fuzzy matching\")\n  .option(\"-c, --column <cols>\", \"filter by column(s), comma-separated\")\n  .option(\"-t, --tags <tags>\", \"filter by tag(s), comma-separated\")\n  .option(\"-l, --limit <n>\", \"maximum number of results\", \"10\")\n  .action(\n    async (\n      query: string,\n      opts: { column?: string; tags?: string; limit: string },\n    ) =>\n      run(async () => {\n        const { board } = await resolveBoard(program.opts())\n\n        const results = await board.searchCards({\n          query,\n          limit: Number.parseInt(opts.limit, 10),\n          ...(opts.column\n            ? {\n                columns: opts.column\n                  .split(\",\")\n                  .map((c) => c.trim())\n                  .filter(Boolean),\n              }\n            : {}),\n          ...(opts.tags\n            ? {\n                tags: opts.tags\n                  .split(\",\")\n                  .map((t) => t.trim())\n                  .filter(Boolean),\n              }\n            : {}),\n        })\n\n        if (results.length === 0) {\n          console.log(chalk.dim(`\\nNo results for \"${query}\".`))\n          return\n        }\n\n        console.log(\n          chalk.bold(`\\nResults for \"${chalk.cyan(query)}\" (${results.length}):`),\n        )\n        for (const card of results) {\n          printCardLine(card)\n        }\n        console.log()\n      }),\n  )\n\nprogram.parse()\n","numLines":552,"startLine":1,"totalLines":552}}}
