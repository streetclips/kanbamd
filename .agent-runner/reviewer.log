{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UFv4vh3c8S4vwVsdnCS9H3","type":"tool_result","content":"1\timport { mkdir, readFile, readdir, rename, rm, stat, writeFile } from \"node:fs/promises\"\n2\timport path from \"node:path\"\n3\timport { BoardRootNotFoundError, CardNotFoundError } from \"./errors.js\"\n4\t\n5\texport type StoredFile = {\n6\t  content: string\n7\t  createdAt: Date\n8\t  updatedAt: Date\n9\t}\n10\t\n11\texport interface StorageAdapter {\n12\t  init(options: {\n13\t    root?: string\n14\t    columns: string[]\n15\t    createRoot: boolean\n16\t    createColumns: boolean\n17\t  }): Promise<void>\n18\t  listMarkdownFiles(column: string): Promise<string[]>\n19\t  readCard(column: string, fileName: string): Promise<StoredFile>\n20\t  writeCard(column: string, fileName: string, content: string): Promise<StoredFile>\n21\t  moveCard(\n22\t    from: { column: string; fileName: string },\n23\t    to: { column: string; fileName: string },\n24\t  ): Promise<void>\n25\t  deleteCard(column: string, fileName: string): Promise<void>\n26\t}\n27\t\n28\texport class FilesystemStorage implements StorageAdapter {\n29\t  async init(options: {\n30\t    root?: string\n31\t    columns: string[]\n32\t    createRoot: boolean\n33\t    createColumns: boolean\n34\t  }): Promise<void> {\n35\t    const root = options.root\n36\t    if (!root) {\n37\t      throw new BoardRootNotFoundError(\"Filesystem storage requires a root directory.\")\n38\t    }\n39\t\n40\t    try {\n41\t      const rootStat = await stat(root)\n42\t      if (!rootStat.isDirectory()) {\n43\t        throw new BoardRootNotFoundError(`Board root is not a directory: ${root}`)\n44\t      }\n45\t    } catch (error) {\n46\t      if (options.createRoot) {\n47\t        await mkdir(root, { recursive: true })\n48\t      } else {\n49\t        throw new BoardRootNotFoundError(`Board root does not exist: ${root}`)\n50\t      }\n51\t    }\n52\t\n53\t    if (options.createColumns) {\n54\t      await Promise.all(\n55\t        options.columns.map((column) => mkdir(path.join(root, column), { recursive: true })),\n56\t      )\n57\t    }\n58\t  }\n59\t\n60\t  async listMarkdownFiles(column: string): Promise<string[]> {\n61\t    const entries = await readdir(column, { withFileTypes: true })\n62\t    return entries\n63\t      .filter((entry) => entry.isFile() && entry.name.endsWith(\".md\"))\n64\t      .map((entry) => entry.name)\n65\t  }\n66\t\n67\t  async readCard(column: string, fileName: string): Promise<StoredFile> {\n68\t    const filePath = path.join(column, fileName)\n69\t    try {\n70\t      const [content, fileStat] = await Promise.all([readFile(filePath, \"utf8\"), stat(filePath)])\n71\t      return {\n72\t        content,\n73\t        createdAt: fileStat.birthtime,\n74\t        updatedAt: fileStat.mtime,\n75\t      }\n76\t    } catch {\n77\t      throw new CardNotFoundError(`Card file not found: ${filePath}`)\n78\t    }\n79\t  }\n80\t\n81\t  async writeCard(column: string, fileName: string, content: string): Promise<StoredFile> {\n82\t    const filePath = path.join(column, fileName)\n83\t    await writeFile(filePath, content, \"utf8\")\n84\t    const fileStat = await stat(filePath)\n85\t    return {\n86\t      content,\n87\t      createdAt: fileStat.birthtime,\n88\t      updatedAt: fileStat.mtime,\n89\t    }\n90\t  }\n91\t\n92\t  async moveCard(\n93\t    from: { column: string; fileName: string },\n94\t    to: { column: string; fileName: string },\n95\t  ): Promise<void> {\n96\t    await rename(path.join(from.column, from.fileName), path.join(to.column, to.fileName))\n97\t  }\n98\t\n99\t  async deleteCard(column: string, fileName: string): Promise<void> {\n100\t    await rm(path.join(column, fileName))\n101\t  }\n102\t}\n103\t\n104\texport class MemoryStorage implements StorageAdapter {\n105\t  private readonly columns = new Map<string, Map<string, StoredFile>>()\n106\t\n107\t  async init(options: { columns: string[] }): Promise<void> {\n108\t    for (const column of options.columns) {\n109\t      if (!this.columns.has(column)) {\n110\t        this.columns.set(column, new Map())\n111\t      }\n112\t    }\n113\t  }\n114\t\n115\t  async listMarkdownFiles(column: string): Promise<string[]> {\n116\t    return [...(this.columns.get(column)?.keys() ?? [])].filter((fileName) =>\n117\t      fileName.endsWith(\".md\"),\n118\t    )\n119\t  }\n120\t\n121\t  async readCard(column: string, fileName: string): Promise<StoredFile> {\n122\t    const file = this.columns.get(column)?.get(fileName)\n123\t    if (!file) {\n124\t      throw new CardNotFoundError(`Card file not found: ${column}/${fileName}`)\n125\t    }\n126\t    return { ...file, createdAt: new Date(file.createdAt), updatedAt: new Date(file.updatedAt) }\n127\t  }\n128\t\n129\t  async writeCard(column: string, fileName: string, content: string): Promise<StoredFile> {\n130\t    const files = this.columns.get(column)\n131\t    if (!files) {\n132\t      throw new CardNotFoundError(`Column not found: ${column}`)\n133\t    }\n134\t\n135\t    const existing = files.get(fileName)\n136\t    const now = new Date()\n137\t    const file = {\n138\t      content,\n139\t      createdAt: existing?.createdAt ?? now,\n140\t      updatedAt: now,\n141\t    }\n142\t    files.set(fileName, file)\n143\t    return { ...file }\n144\t  }\n145\t\n146\t  async moveCard(\n147\t    from: { column: string; fileName: string },\n148\t    to: { column: string; fileName: string },\n149\t  ): Promise<void> {\n150\t    const source = this.columns.get(from.column)\n151\t    const target = this.columns.get(to.column)\n152\t    const file = source?.get(from.fileName)\n153\t    if (!source || !target || !file) {\n154\t      throw new CardNotFoundError(`Card file not found: ${from.column}/${from.fileName}`)\n155\t    }\n156\t\n157\t    source.delete(from.fileName)\n158\t    target.set(to.fileName, { ...file, updatedAt: new Date() })\n159\t  }\n160\t\n161\t  async deleteCard(column: string, fileName: string): P