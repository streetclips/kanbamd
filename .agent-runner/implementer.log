{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P96ZfKMUPwsVZVKQSKtEjN","type":"tool_result","content":"1\timport { spawnSync } from \"node:child_process\"\n2\timport { readFile, writeFile } from \"node:fs/promises\"\n3\t\n4\tconst releaseTypes = new Set([\n5\t  \"major\",\n6\t  \"minor\",\n7\t  \"patch\",\n8\t  \"fix\",\n9\t  \"premajor\",\n10\t  \"preminor\",\n11\t  \"prepatch\",\n12\t  \"prerelease\",\n13\t])\n14\t\n15\tconst args = process.argv.slice(2)\n16\t\n17\tmain().catch((error) => {\n18\t  console.error(error instanceof Error ? error.message : error)\n19\t  process.exit(1)\n20\t})\n21\t\n22\tasync function main() {\n23\t  const { releaseType, options } = parseArgs(args)\n24\t  const releaseBranch = \"dev\"\n25\t  const currentBranch = getCurrentBranch()\n26\t\n27\t  if (currentBranch !== releaseBranch) {\n28\t    throw new Error(\n29\t      `Release must be run from ${releaseBranch}; current branch is ${currentBranch}.`,\n30\t    )\n31\t  }\n32\t\n33\t  assertCleanWorkingTree()\n34\t\n35\t  if (!options.skipChecks) {\n36\t    run(\"npm\", [\"run\", \"lint\"])\n37\t    run(\"npm\", [\"run\", \"typecheck\"])\n38\t    run(\"npm\", [\"run\", \"test\"])\n39\t  }\n40\t\n41\t  const originalPackageJson = await readFile(\"package.json\", \"utf8\")\n42\t  const packageJson = JSON.parse(originalPackageJson)\n43\t  const previousVersion = packageJson.version\n44\t  const nextVersion = bumpVersion(previousVersion, releaseType, options.preid)\n45\t  packageJson.version = nextVersion\n46\t\n47\t  let shouldRollbackPackageJson = true\n48\t  let didStagePackageJson = false\n49\t  try {\n50\t    await writeFile(\"package.json\", `${JSON.stringify(packageJson, null, 2)}\\n`, \"utf8\")\n51\t    console.log(`${packageJson.name}: ${previousVersion} -> ${nextVersion}`)\n52\t\n53\t    run(\"npm\", [\"run\", \"build\"])\n54\t\n55\t    if (options.dryRun) {\n56\t      await restorePackageJson(originalPackageJson)\n57\t      shouldRollbackPackageJson = false\n58\t      console.log(\"Dry run complete. Restored package.json.\")\n59\t      return\n60\t    }\n61\t\n62\t    run(\"git\", [\"add\", \"package.json\"])\n63\t    didStagePackageJson = true\n64\t    run(\"git\", [\"commit\", \"-m\", `[dev] bump version ${nextVersion}`])\n65\t    shouldRollbackPackageJson = false\n66\t  } catch (error) {\n67\t    if (shouldRollbackPackageJson) {\n68\t      await rollbackPackageJson(originalPackageJson, previousVersion, didStagePackageJson)\n69\t    }\n70\t    throw error\n71\t  }\n72\t\n73\t  run(\"git\", [\"push\", \"origin\", releaseBranch])\n74\t\n75\t  try {\n76\t    checkoutBranch(options.targetBranch)\n77\t    run(\"git\", [\"merge\", \"--ff-only\", releaseBranch])\n78\t\n79\t    run(\"git\", [\"push\", \"origin\", options.targetBranch])\n80\t    console.log(`Pushed ${options.targetBranch}. GitHub Actions will publish v${nextVersion}.`)\n81\t  } finally {\n82\t    checkoutBranch(releaseBranch)\n83\t  }\n84\t}\n85\t\n86\tfunction parseArgs(argv) {\n87\t  const [rawReleaseType, ...rawOptions] = argv\n88\t\n89\t  if (!rawReleaseType || rawReleaseType === \"-h\" || rawReleaseType === \"--help\") {\n90\t    printHelp()\n91\t    process.exit(rawReleaseType ? 0 : 1)\n92\t  }\n93\t\n94\t  if (!releaseTypes.has(rawReleaseType)) {\n95\t    throw new Error(`Unknown release type: ${rawReleaseType}`)\n96\t  }\n97\t\n98\t  const options = {\n99\t    dryRun: false,\n100\t    skipChecks: false,\n101\t    preid: \"next\",\n102\t    targetBranch: \"main\",\n103\t  }\n104\t\n105\t  for (let index = 0; index < rawOptions.length; index += 1) {\n106\t    const option = rawOptions[index]\n107\t\n108\t    if (option === \"--dry-run\") {\n109\t      options.dryRun = true\n110\t      continue\n111\t    }\n112\t\n113\t    if (option === \"--skip-checks\") {\n114\t      options.skipChecks = true\n115\t      continue\n116\t    }\n117\t\n118\t    if (option === \"--preid\") {\n119\t      options.preid = readOptionValue(rawOptions, index, option)\n120\t      index += 1\n121\t      continue\n122\t    }\n123\t\n124\t    if (option === \"--target-branch\") {\n125\t      options.targetBranch = readOptionValue(rawOptions, index, option)\n126\t      index += 1\n127\t      continue\n128\t    }\n129\t\n130\t    throw new Error(`Unknown option: ${option}`)\n131\t  }\n132\t\n133\t  const releaseType = rawReleaseType === \"fix\" ? \"patch\" : rawReleaseType\n134\t\n135\t  return {\n136\t    releaseType,\n137\t    options,\n138\t  }\n139\t}\n140\t\n141\tfunction readOptionValue(options, index, name) {\n142\t  const value = options[index + 1]\n143\t  if (!value || value.startsWith(\"--\")) {\n144\t    throw new Error(`${name} requires a value`)\n145\t  }\n146\t  return value\n147\t}\n148\t\n149\tasync function restorePackageJson(originalPackageJson) {\n150\t  await writeFile(\"package.json\", originalPackageJson, \"utf8\")\n151\t}\n152\t\n153\tasync function rollbackPackageJson(originalPackageJson, previousVersion, restage) {\n154\t  await restorePackageJson(originalPackageJson)\n155\t  if (restage) {\n156\t    run(\"git\", [\"add\", \"package.json\"])\n157\t  }\n158\t  console.error(`Restored package version to ${previousVersion}.`)\n159\t}\n160\t\n161\tfunction bumpVersion(version, releaseType, preid) {\n162\t  const parsed = parseVersion(version)\n163\t\n164\t  if (releaseType === \"major\") {\n165\t    return `${parsed.major + 1}.0.0`\n166\t  }\n167\t\n168\t  if (releaseType === \"minor\") {\n169\t    return `${parsed.major}.${parsed.minor + 1}.0`\n170\t  }\n171\t\n172\t  if (releaseType === \"patch\") {\n173\t    return `${parsed.major}.${parsed.minor}.${parsed.patch + 1}`\n174\t  }\n175\t\n176\t  if (releaseType === \"premajor\") {\n177\t    return `${parsed.major + 1}.0.0-${preid}.0`\n178\t  }\n179\t\n180\t  if (releaseType === \"preminor\") {\n181\t    return `${parsed.major}.${parsed.minor + 1}.0-${preid}.0`\n182\t  }\n183\t\n184\t  if (releaseType === \"prepatch\") {\n185\t    return `${parsed.major}.${parsed.minor}.${parsed.patch + 1}-${preid}.0`\n186\t  }\n187\t\n188\t  if (!parsed.prerelease) {\n189\t    return `${parsed.major}.${parsed.minor}.${parsed.patch + 1}-${preid}.0`\n190\t  }\n191\t\n192\t  const prereleaseParts = parsed.prerelease.split(\".\")\n193\t  const lastPart = prereleaseParts.at(-1)\n194\t  const nextNumber = lastPart && /^\\d+$/.test(lastPart) ? Number(lastPart) + 1 : 0\n195\t  const nextPrerelease =\n196\t    lastPart && /^\\d+$/.test(lastPart)\n197\t      ? [...prereleaseParts.slice(0, -1), String(nextNumber)].join(\".\")\n198\t      : `${parsed.prerelease}.${nextNumber}`\n199\t\n200\t  return `${parsed.major}.${parsed.minor}.${parsed.patch}-${nextPrerelease}`\n201\t}\n202\t\n203\tfunction parseVersion(version) {\n204\t  const match = version.match(/^(\\d+)\\.(\\d+)\\.(\\d+)(?:-([0-9A-Za-z.-]+))?$/)\n205\t  if (!match) {\n206\t    throw new Error(`Unsupported package version: ${version}`)\n207\t  }\n208\t\n209\t  return {\n210\t    major: Number(match[1]),\n211\t    minor: Number(match[2]),\n212\t    patch: Number(match[3]),\n213\t    prerelease: match[4],\n214\t  }\n215\t}\n216\t\n217\tfunction assertCleanWorkingTree() {\n218\t  const result = spawnSync(\"git\", [\"status\", \"--porcelain\"], {\n219\t    encoding: \"utf8\",\n220\t    stdio: [\"ignore\", \"pipe\", \"pipe\"],\n221\t  })\n222\t\n223\t  if (result.status !== 0) {\n224\t    throw new Error(result.stderr || \"Could not check git status\")\n225\t  }\n226\t\n227\t  if (result.stdout.trim()) {\n228\t    throw new Error(\"Working tree is not clean. Commit or stash changes before releasing.\")\n229\t  }\n230\t}\n231\t\n232\tfunction getCurrentBranch() {\n233\t  return readGit([\"branch\", \"--show-current\"]) || \"HEAD\"\n234\t}\n235\t\n236\tfunction checkoutBranch(branch) {\n237\t  if (branchExists(branch)) {\n238\t    run(\"git\", [\"checkout\", branch])\n239\t    return\n240\t  }\n241\t\n242\t  if (remoteBranchExists(branch)) {\n243\t    run(\"git\", [\"checkout\", \"-b\", branch, `origin/${branch}`])\n244\t    return\n245\t  }\n246\t\n247\t  throw new Error(`Branch not found: ${branch}`)\n248\t}\n249\t\n250\tfunction branchExists(branch) {\n251\t  return gitSucceeds([\"rev-parse\", \"--verify\", `refs/heads/${branch}`])\n252\t}\n253\t\n254\tfunction remoteBranchExists(branch) {\n255\t  return gitSucceeds([\"rev-parse\", \"--verify\", `refs/remotes/origin/${branch}`])\n256\t}\n257\t\n258\tfunction readGit(args) {\n259\t  const result = spawnSync(\"git\", args, {\n260\t    encoding: \"utf8\",\n261\t    stdio: [\"ignore\", \"pipe\", \"pipe\"],\n262\t    shell: false,\n263\t  })\n264\t\n265\t  if (result.status !== 0) {\n266\t    throw new Error(result.stderr || `Command failed: git ${args.join(\" \")}`)\n267\t  }\n268\t\n269\t  return result.stdout.trim()\n270\t}\n271\t\n272\tfunction gitSucceeds(args) {\n273\t  const result = spawnSync(\"git\", args, {\n274\t    stdio: \"ignore\",\n275\t    shell: false,\n276\t  })\n277\t\n278\t  return result.status === 0\n279\t}\n280\t\n281\tfunction run(command, args) {\n282\t  const result = spawnSync(command, args, {\n283\t    stdio: \"inherit\",\n284\t    shell: false,\n285\t  })\n286\t\n287\t  if (result.status !== 0) {\n288\t    throw new Error(`Command failed: ${command} ${args.join(\" \")}`)\n289\t  }\n290\t}\n291\t\n292\tfunction printHelp() {\n293\t  console.log(`Usage:\n294\t  npm run release -- <major|minor|patch|fix|premajor|preminor|prepatch|prerelease> [options]\n295\t\n296\tOptions:\n297\t  --dry-run          Validate the version bump and build without committing or merging.\n298\t  --preid <id>       Prerelease identifier. Defaults to next.\n299\t  --skip-checks      Skip lint, typecheck, and test.\n300\t  --target-branch <branch>\n301\t                     Branch that triggers publishing. Defaults to main.\n302\t\n303\tExamples:\n304\t  npm run release -- fix\n305\t  npm run release -- minor\n306\t  npm run release -- preminor --preid beta\n307\t  npm run release -- patch --dry-run\n308\t`)\n309\t}\n310\t"}]},"parent_tool_use_id":"toolu_01BrUQ3fpGf4pAR1y7j5MwPd","session_id":"aca4f6fe-3a5e-40b8-aa2d-1dcc85197f84","uuid":"e83edc64-1320-4244-b539-3ae856b525ab","timestamp":"2026-05-03T17:04:50.927Z"}
