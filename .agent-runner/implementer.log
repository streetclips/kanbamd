{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TaLmFPLgdZHaK1dxh47H91","type":"tool_result","content":"1\timport { mkdir, mkdtemp, writeFile } from \"node:fs/promises\"\n2\timport os from \"node:os\"\n3\timport path from \"node:path\"\n4\timport { describe, expect, it } from \"vitest\"\n5\timport { InvalidFrontmatterError, Kanbamd } from \"../src/index.js\"\n6\t\n7\ttype ProjectFields = {\n8\t  priority?: \"low\" | \"medium\" | \"high\"\n9\t}\n10\t\n11\tdescribe(\"Kanbamd memory storage\", () => {\n12\t  it(\"creates cards with unique slugs and automatic order\", async () => {\n13\t    const board = new Kanbamd<ProjectFields>({\n14\t      storage: \"memory\",\n15\t      columns: [\"todo\", \"doing\"],\n16\t    })\n17\t\n18\t    await board.init()\n19\t\n20\t    const first = await board.createCard(\"todo\", {\n21\t      title: \"Fix Login\",\n22\t      tags: [\"bug\"],\n23\t      body: \"The login flow is broken.\",\n24\t      frontmatter: { priority: \"high\" },\n25\t    })\n26\t    const second = await board.createCard(\"todo\", {\n27\t      title: \"Fix Login\",\n28\t      tags: [\"bug\"],\n29\t    })\n30\t\n31\t    expect(first.id).toBe(\"fix-login\")\n32\t    expect(second.id).toBe(\"fix-login-2\")\n33\t    expect(first.frontmatter.order).toBe(1)\n34\t    expect(second.frontmatter.order).toBe(2)\n35\t    expect(first.frontmatter.priority).toBe(\"high\")\n36\t  })\n37\t\n38\t  it(\"updates cards without allowing reserved frontmatter writes\", async () => {\n39\t    const board = new Kanbamd<ProjectFields>({\n40\t      storage: \"memory\",\n41\t      columns: [\"todo\"],\n42\t    })\n43\t\n44\t    await board.init()\n45\t    await board.createCard(\"todo\", {\n46\t      title: \"Refactor API\",\n47\t      tags: [\"tech-debt\"],\n48\t      body: \"Old body\",\n49\t    })\n50\t\n51\t    const updated = await board.updateCard(\n52\t      { column: \"todo\", id: \"refactor-api\" },\n53\t      {\n54\t        title: \"Refactor API Client\",\n55\t        tags: [\"tech-debt\", \"api\"],\n56\t        body: \"New body\",\n57\t        frontmatter: { priority: \"medium\" },\n58\t      },\n59\t    )\n60\t\n61\t    expect(updated.frontmatter.title).toBe(\"Refactor API Client\")\n62\t    expect(updated.frontmatter.tags).toEqual([\"tech-debt\", \"api\"])\n63\t    expect(updated.body).toBe(\"New body\\n\")\n64\t    expect(updated.frontmatter.priority).toBe(\"medium\")\n65\t\n66\t    await expect(\n67\t      board.updateCard(\n68\t        { column: \"todo\", id: \"refactor-api\" },\n69\t        { frontmatter: { order: 10 } as never },\n70\t      ),\n71\t    ).rejects.toBeInstanceOf(InvalidFrontmatterError)\n72\t  })\n73\t\n74\t  it(\"rejects invalid card input before writing\", async () => {\n75\t    const board = new Kanbamd({\n76\t      storage: \"memory\",\n77\t      columns: [\"todo\"],\n78\t    })\n79\t\n80\t    await board.init()\n81\t\n82\t    await expect(board.createCard(\"todo\", { title: \"\", tags: [] })).rejects.toBeInstanceOf(\n83\t      InvalidFrontmatterError,\n84\t    )\n85\t    await expect(board.getCard({ column: \"todo\", id: \"../escape\" })).rejects.toThrow(\n86\t      \"Invalid card id\",\n87\t    )\n88\t    await expect(board.listCards({ column: \"todo\" })).resolves.toEqual([])\n89\t  })\n90\t\n91\t  it(\"moves and reorders cards while normalizing integer order\", async () => {\n92\t    const board = new Kanbamd({\n93\t      storage: \"memory\",\n94\t      columns: [\"todo\", \"doing\"],\n95\t    })\n96\t\n97\t    await board.init()\n98\t    await board.createCard(\"todo\", { title: \"First\", tags: [] })\n99\t    await board.createCard(\"todo\", { title: \"Second\", tags: [] })\n100\t    await board.createCard(\"todo\", { title: \"Third\", tags: [] })\n101\t\n102\t    await board.reorderCard({ column: \"todo\", id: \"third\" }, 0)\n103\t    let todo = await board.listCards({ column: \"todo\" })\n104\t    expect(todo.map((card) => [card.id, card.frontmatter.order])).toEqual([\n105\t      [\"third\", 1],\n106\t      [\"first\", 2],\n107\t      [\"second\", 3],\n108\t    ])\n109\t\n110\t    const moved = await board.moveCard({ column: \"todo\", id: \"first\" }, { column: \"doing\" })\n111\t    expect(moved.column).toBe(\"doing\")\n112\t    expect(moved.frontmatter.order).toBe(1)\n113\t\n114\t    todo = await board.listCards({ column: \"todo\" })\n115\t    expect(todo.map((card) => [card.id, card.frontmatter.order])).toEqual([\n116\t      [\"third\", 1],\n117\t      [\"second\", 2],\n118\t    ])\n119\t  })\n120\t\n121\t  it(\"searches cards fuzzily and filters by tags\", async () => {\n122\t    const board = new Kanbamd({\n123\t      storage: \"memory\",\n124\t      columns: [\"todo\", \"done\"],\n125\t    })\n126\t\n127\t    await board.init()\n128\t    await board.createCard(\"todo\", {\n129\t      title: \"Login regression\",\n130\t      tags: [\"bug\"],\n131\t      body: \"OAuth callback fails.\",\n132\t    })\n133\t    await board.createCard(\"done\", {\n134\t      title: \"Marketing copy\",\n135\t      tags: [\"content\"],\n136\t      body: \"Landing page text.\",\n137\t    })\n138\t\n139\t    const results = await board.searchCards({\n140\t      query: \"logn regresion\",\n141\t      tags: [\"bug\"],\n142\t    })\n143\t\n144\t    expect(results.map((card) => card.id)).toEqual([\"login-regression\"])\n145\t  })\n146\t})\n147\t\n148\tdescribe(\"Kanbamd filesystem storage\", () => {\n149\t  it(\"requires an existing root unless createRoot is enabled and creates columns\", async () => {\n150\t    const tmpRoot = await mkdtemp(path.join(os.tmpdir(), \"kanbamd-\"))\n151\t    const root = path.join(tmpRoot, \"board\")\n152\t\n153\t    const failingBoard = new Kanbamd({\n154\t      root,\n155\t      columns: [\"todo\"],\n156\t    })\n157\t    await expect(failingBoard.init()).rejects.toThrow(`Board root does not exist: ${root}`)\n158\t\n159\t    await mkdir(root)\n160\t    const board = new Kanbamd({\n161\t      root,\n162\t      columns: [\"todo\", \"doing\"],\n163\t      createColumns: true,\n164\t    })\n165\t\n166\t    await board.init()\n167\t    const card = await board.createCard(\"todo\", {\n168\t      title: \"Write docs\",\n169\t      tags: [\"docs\"],\n170\t      body: \"Add README.\",\n171\t    })\n172\t\n173\t    expect(card.id).toBe(\"write-docs\")\n174\t    await expect(board.getCard({ column: \"todo\", id: \"write-docs\" })).resolves.toMatchObject({\n175\t      id: \"write-docs\",\n176\t      column: \"todo\",\n177\t    })\n178\t  })\n179\t\n180\t  it(\"throws InvalidFrontmatterError for malformed markdown cards\", async () => {\n181\t    const root = await mkdtemp(path.join(os.tmpdir(), \"kanbamd-\"))\n182\t    await mkdir(path.join(root, \"todo\"))\n183\t    await writeFile(\n184\t      path.join(root, \"todo\", \"broken.md\"),\n185\t      \"---\\ntags: []\\norder: 1\\n---\\nBody\",\n186\t      \"utf8\",\n187\t    )\n188\t\n189\t    const board = new Kanbamd({\n190\t      root,\n191\t      columns: [\"todo\"],\n192\t    })\n193\t\n194\t    await board.init()\n195\t\n196\t    await expect(board.listCards({ column: \"todo\" })).rejects.toBeInstanceOf(\n197\t      InvalidFrontmatterError,\n198\t    )\n199\t  })\n200\t})\n201\t"}]},"parent_tool_use_id":"toolu_01BrUQ3fpGf4pAR1y7j5MwPd","session_id":"aca4f6fe-3a5e-40b8-aa2d-1dcc85197f84","uuid":"bc8e13bd-b5db-4c12-b4cc-be1efcb4d735","timestamp":"2026-05-03T17:04:49.081Z"}
