{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SCSdHQxZTMhkSE6VpdyFMf","type":"tool_result","content":"1\tname: Release\n2\t\n3\ton:\n4\t  push:\n5\t    branches:\n6\t      - main\n7\t  workflow_dispatch:\n8\t\n9\tpermissions:\n10\t  contents: write\n11\t\n12\tjobs:\n13\t  publish:\n14\t    name: Publish package\n15\t    runs-on: ubuntu-latest\n16\t\n17\t    steps:\n18\t      - name: Checkout\n19\t        uses: actions/checkout@v6\n20\t        with:\n21\t          fetch-depth: 0\n22\t\n23\t      - name: Setup Node\n24\t        uses: actions/setup-node@v6\n25\t        with:\n26\t          node-version: 20\n27\t          registry-url: https://registry.npmjs.org\n28\t          cache: npm\n29\t\n30\t      - name: Install dependencies\n31\t        run: npm ci\n32\t\n33\t      - name: Setup Biome\n34\t        uses: biomejs/setup-biome@v2\n35\t\n36\t      - name: Check\n37\t        run: |\n38\t          biome ci .\n39\t          npm run typecheck\n40\t          npm run test\n41\t\n42\t      - name: Build\n43\t        run: npm run build\n44\t\n45\t      - name: Read package version\n46\t        id: package\n47\t        run: |\n48\t          PACKAGE_NAME=\"$(node -p \"require('./package.json').name\")\"\n49\t          VERSION=\"$(node -p \"require('./package.json').version\")\"\n50\t          RELEASE_TAG=\"v${VERSION}\"\n51\t          NPM_TAG=\"latest\"\n52\t\n53\t          if [[ \"${VERSION}\" == *-* ]]; then\n54\t            PRERELEASE=\"${VERSION#*-}\"\n55\t            NPM_TAG=\"${PRERELEASE%%.*}\"\n56\t          fi\n57\t\n58\t          if git tag --list \"${RELEASE_TAG}\" | grep -q \"^${RELEASE_TAG}$\"; then\n59\t            EXISTS=\"true\"\n60\t          else\n61\t            EXISTS=\"false\"\n62\t          fi\n63\t\n64\t          if npm view \"${PACKAGE_NAME}@${VERSION}\" version >/dev/null 2>&1; then\n65\t            PUBLISHED=\"true\"\n66\t          else\n67\t            PUBLISHED=\"false\"\n68\t          fi\n69\t\n70\t          echo \"package_name=${PACKAGE_NAME}\" >> \"$GITHUB_OUTPUT\"\n71\t          echo \"version=${VERSION}\" >> \"$GITHUB_OUTPUT\"\n72\t          echo \"release_tag=${RELEASE_TAG}\" >> \"$GITHUB_OUTPUT\"\n73\t          echo \"npm_tag=${NPM_TAG}\" >> \"$GITHUB_OUTPUT\"\n74\t          echo \"exists=${EXISTS}\" >> \"$GITHUB_OUTPUT\"\n75\t          echo \"published=${PUBLISHED}\" >> \"$GITHUB_OUTPUT\"\n76\t\n77\t      - name: Publish to npm\n78\t        if: steps.package.outputs.published == 'false'\n79\t        run: npm publish --access public --tag \"${{ steps.package.outputs.npm_tag }}\"\n80\t        env:\n81\t          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}\n82\t\n83\t      - name: Skip existing npm version\n84\t        if: steps.package.outputs.published == 'true'\n85\t        run: echo \"${{ steps.package.outputs.package_name }}@${{ steps.package.outputs.version }} is already published; skipping npm publish.\"\n86\t\n87\t      - name: Create GitHub Release\n88\t        if: steps.package.outputs.exists == 'false'\n89\t        run: gh release create \"${{ steps.package.outputs.release_tag }}\" --title \"${{ steps.package.outputs.release_tag }}\" --notes \"Release ${{ steps.package.outputs.release_tag }}\" --target \"$GITHUB_SHA\"\n90\t        env:\n91\t          GH_TOKEN: ${{ github.token }}\n92\t\n93\t      - name: Skip existing release\n94\t        if: steps.package.outputs.exists == 'true'\n95\t        run: echo \"Release ${{ steps.package.outputs.release_tag }} already exists; skipping GitHub Release creation.\"\n96\t"}]},"parent_tool_use_id":"toolu_01BrUQ3fpGf4pAR1y7j5MwPd","session_id":"aca4f6fe-3a5e-40b8-aa2d-1dcc85197f84","uuid":"e5da9806-a21f-4437-96d3-04351201b305","timestamp":"2026-05-03T17:04:54.993Z"}
