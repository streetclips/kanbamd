{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kje2uYA4W7MPPivyS86SSx","type":"tool_result","content":"1\timport { mkdir, mkdtemp, writeFile } from \"node:fs/promises\"\n2\timport os from \"node:os\"\n3\timport path from \"node:path\"\n4\timport { describe, expect, it } from \"vitest\"\n5\timport { InvalidFrontmatterError, Kanbamd } from \"../src/index.js\"\n6\t\n7\ttype ProjectFields = {\n8\t  priority?: \"low\" | \"medium\" | \"high\"\n9\t}\n10\t\n11\tdescribe(\"Kanbamd memory storage\", () => {\n12\t  it(\"creates cards with unique slugs and automatic order\", async () => {\n13\t    const board = new Kanbamd<ProjectFields>({\n14\t      storage: \"memory\",\n15\t      columns: [\"todo\", \"doing\"],\n16\t    })\n17\t\n18\t    await board.init()\n19\t\n20\t    const first = await board.createCard(\"todo\", {\n21\t      title: \"Fix Login\",\n22\t      tags: [\"bug\"],\n23\t      body: \"The login flow is broken.\",\n24\t      frontmatter: { priority: \"high\" },\n25\t    })\n26\t    const second = await board.createCard(\"todo\", {\n27\t      title: \"Fix Login\",\n28\t      tags: [\"bug\"],\n29\t    })\n30\t\n31\t    expect(first.id).toBe(\"fix-login\")\n32\t    expect(second.id).toBe(\"fix-login-2\")\n33\t    expect(first.frontmatter.order).toBe(1)\n34\t    expect(second.frontmatter.order).toBe(2)\n35\t    expect(first.frontmatter.priority).toBe(\"high\")\n36\t  })\n37\t\n38\t  it(\"updates cards without allowing reserved frontmatter writes\", async () => {\n39\t    const board = new Kanbamd<ProjectFields>({\n40\t      storage: \"memory\",\n41\t      columns: [\"todo\"],\n42\t    })\n43\t\n44\t    await board.init()\n45\t    await board.createCard(\"todo\", {\n46\t      title: \"Refactor API\",\n47\t      tags: [\"tech-debt\"],\n48\t      body: \"Old body\",\n49\t    })\n50\t\n51\t    const updated = await board.updateCard(\n52\t      { column: \"todo\", id: \"refactor-api\" },\n53\t      {\n54\t        title: \"Refactor API Client\",\n55\t        tags: [\"tech-debt\", \"api\"],\n56\t        body: \"New body\",\n57\t        frontmatter: { priority: \"medium\" },\n58\t      },\n59\t    )\n60\t\n61\t    expect(updated.frontmatter.title).toBe(\"Refactor API Client\")\n62\t    expect(updated.frontmatter.tags).toEqual([\"tech-debt\", \"api\"])\n63\t    expect(updated.body).toBe(\"New body\\n\")\n64\t    expect(updated.frontmatter.priority).toBe(\"medium\")\n65\t\n66\t    await expect(\n67\t      board.updateCard(\n68\t        { column: \"todo\", id: \"refactor-api\" },\n69\t        { frontmatter: { order: 10 } as never },\n70\t      ),\n71\t    ).rejects.toBeInstanceOf(InvalidFrontmatterError)\n72\t  })\n73\t\n74\t  it(\"rejects invalid card input before writing\", async () => {\n75\t    const board = new Kanbamd({\n76\t      storage: \"memory\",\n77\t      columns: [\"todo\"],\n78\t    })\n79\t\n80\t    await board.init()"}]},"parent_tool_use_id":"toolu_013DMbBCUJEutCNiiZ1iEm88","session_id":"68094eb4-e892-4d4e-90de-f1d86bf44291","uuid":"0f270e89-e995-4b3e-91b4-8d5b022535e8","timestamp":"2026-05-03T16:59:46.426Z"}
