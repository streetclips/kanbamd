{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GizY8XZ6wyKnVWk98pbrna","type":"tool_result","content":"1\texport type ReservedFrontmatterKey = \"title\" | \"tags\" | \"order\"\n2\t\n3\texport type ExtraFrontmatter = object\n4\t\n5\texport type NoReservedFrontmatter<T extends ExtraFrontmatter> = T & {\n6\t  [K in Extract<keyof T, ReservedFrontmatterKey>]: never\n7\t}\n8\t\n9\texport type BaseFrontmatter = {\n10\t  title: string\n11\t  tags: string[]\n12\t  order: number\n13\t}\n14\t\n15\texport type CardFrontmatter<T extends ExtraFrontmatter = ExtraFrontmatter> = BaseFrontmatter &\n16\t  NoReservedFrontmatter<T>\n17\t\n18\texport type Card<T extends ExtraFrontmatter = ExtraFrontmatter> = {\n19\t  id: string\n20\t  fileName: string\n21\t  column: string\n22\t  frontmatter: CardFrontmatter<T>\n23\t  body: string\n24\t  createdAt: Date\n25\t  updatedAt: Date\n26\t}\n27\t\n28\texport type CardLocator = {\n29\t  column: string\n30\t  id: string\n31\t}\n32\t\n33\texport type CreateCardInput<T extends ExtraFrontmatter = ExtraFrontmatter> = {\n34\t  title: string\n35\t  tags?: string[]\n36\t  body?: string\n37\t  frontmatter?: NoReservedFrontmatter<T>\n38\t}\n39\t\n40\texport type UpdateCardInput<T extends ExtraFrontmatter = ExtraFrontmatter> = {\n41\t  title?: string\n42\t  tags?: string[]\n43\t  body?: string\n44\t  frontmatter?: Partial<NoReservedFrontmatter<T>>\n45\t}\n46\t\n47\texport type ListCardsOptions = {\n48\t  column?: string\n49\t}\n50\t\n51\texport type SearchCardsOptions = {\n52\t  query: string\n53\t  columns?: string[]\n54\t  tags?: string[]\n55\t  limit?: number\n56\t}\n57\t\n58\texport type StorageKind = \"filesystem\" | \"memory\"\n59\t\n60\texport type KanbamdOptions = {\n61\t  root?: string\n62\t  columns: string[]\n63\t  createRoot?: boolean\n64\t  createColumns?: boolean\n65\t  storage?: StorageKind\n66\t}\n67\t"}]},"parent_tool_use_id":"toolu_01BrUQ3fpGf4pAR1y7j5MwPd","session_id":"aca4f6fe-3a5e-40b8-aa2d-1dcc85197f84","uu