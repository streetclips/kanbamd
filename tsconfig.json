{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "#src/*": ["./src/*.ts"],
      "#test/*": ["./test/*.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
